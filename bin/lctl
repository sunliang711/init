#!/bin/bash
rpath="$(readlink "${BASH_SOURCE[0]}")"
if [ -z "$rpath" ];then
    rpath=${BASH_SOURCE[0]}
fi
thisDir="$(cd "$(dirname "$rpath")" && pwd)"
cd "$thisDir" || exit 1

user="${SUDO_USER:-$(whoami)}"
home="$(eval echo ~"$user")"

red=$(tput setaf 1)
bold=$(tput bold)
reset=$(tput sgr0)
function runAsRoot(){
    verbose=0
    while getopts ":v" opt;do
        case "$opt" in
            v)
                verbose=1
                ;;
            \?)
                echo "Unknown option: \"$OPTARG\""
                exit 1
                ;;
        esac
    done
    shift $((OPTIND-1))
    cmd="$*"
    if [ -z "$cmd" ];then
        echo "${red}Need cmd${reset}"
        exit 1
    fi

    if [ "$verbose" -eq 1 ];then
        echo "run cmd:\"${red}$cmd${reset}\" as root."
    fi

    if ((EUID==0));then
        sh -c "$cmd"
    else
        if ! command -v sudo >/dev/null 2>&1;then
            echo "Need sudo cmd"
            exit 1
        fi
        sudo sh -c "$cmd"
    fi
}
###############################################################################
# write your code below (just define function[s])
# function with 'function' is hidden when run help, without 'function' is show
###############################################################################
agentPath=$home/Library/LaunchAgents
if [ "$(uname)" != "Darwin" ];then
    echo "Only on MacOS"
    exit 1
fi

function agentname(){
    local name=${1}
    if [ -z "$name" ];then
        echo "need agent name."
        exit 1
    fi
    if [[ "$name" == */* ]];then
        echo "Agent name must not contain slash."
        exit 1
    fi
    if [[ ! "$name" =~ ^[A-Za-z0-9._-]+$ ]];then
        echo "Agent name can only contain letters, numbers, dot, underscore and hyphen."
        exit 1
    fi
    name=${name%.plist}.plist
    agentfullname="$agentPath/$name"
}

# 从 agent plist 路径取默认 Label。
function defaultAgentLabel(){
    basename "$agentfullname" .plist
}

# 校验目标 plist 存在，避免后续命令作用在错误路径上。
function ensureAgentFile(){
    if [ ! -f "$agentfullname" ];then
        echo "${red}Agent file not found: $agentfullname${reset}"
        exit 1
    fi
}

# start/stop 需要 LaunchAgent Label，优先从 plist 读取。
function agentlabel(){
    ensureAgentFile
    agentLabel=$(/usr/libexec/PlistBuddy -c "Print :Label" "$agentfullname" 2>/dev/null)
    if [ -z "$agentLabel" ];then
        agentLabel="$(defaultAgentLabel)"
    fi
}

# 校验新建目标不存在，避免覆盖现有 plist。
function ensureNewAgentFile(){
    if [ -e "$agentfullname" ];then
        echo "${red}Agent file already exists: $agentfullname${reset}"
        exit 1
    fi
}

# 确保 LaunchAgents 目录存在，新建 plist 前使用。
function ensureAgentPath(){
    if [ ! -d "$agentPath" ];then
        mkdir -p "$agentPath"
    fi
}

# 生成当前用户 LaunchAgent 所在的 launchd domain。
function launchctlDomain(){
    local uid
    uid="$(id -u "$user" 2>/dev/null || id -u)"
    echo "gui/$uid"
}

# 从指定 plist 读取 Label，缺失时回退到文件名。
function agentLabelFromFile(){
    local plist name label
    plist="$1"
    name="$(basename "$plist")"
    label=$(/usr/libexec/PlistBuddy -c "Print :Label" "$plist" 2>/dev/null)
    if [ -z "$label" ];then
        label="${name%.plist}"
    fi
    echo "$label"
}

# 查询指定 Label 的加载和运行状态，结果写入 launchStatus 等变量。
function setLaunchStatus(){
    local label domain info
    label="$1"
    domain="$(launchctlDomain)"
    launchStatus="unloaded"
    launchRunning="stopped"
    launchPid="-"
    launchMark="○"
    if info="$(launchctl print "$domain/$label" 2>/dev/null)";then
        launchStatus="loaded"
        launchMark="●"
        launchPid="$(printf "%s\n" "$info" | awk -F' = ' '/^[[:space:]]*pid = / {print $2; exit}')"
        if [ -n "$launchPid" ];then
            launchRunning="running"
        else
            launchPid="-"
        fi
    fi
}

# 打印状态表头，供 list/status 共用。
function printLaunchStatusHeader(){
    printf "%s %-10s %-8s %-8s %-45s %s\n" "MARK" "STATUS" "RUNNING" "PID" "LABEL" "PLIST"
}

# 打印单行 LaunchAgent 状态，供 list/status 共用。
function printLaunchStatusRow(){
    local label name
    label="$1"
    name="$2"
    printf "%s    %-10s %-8s %-8s %-45s %s\n" "$launchMark" "$launchStatus" "$launchRunning" "$launchPid" "$label" "$name"
}

# 清理 new 命令创建的临时 plist，除非需要保留给用户修正。
function cleanupNewTmpfile(){
    if [ -n "$newTmpfile" ] && [ "$keepNewTmpfile" -eq 0 ];then
        /bin/rm -f "$newTmpfile"
    fi
}

load(){
    agentname "$1"
    agentlabel
    local domain
    domain="$(launchctlDomain)"
    launchctl enable "$domain/$agentLabel" >/dev/null 2>&1 || true
    launchctl bootstrap "$domain" "$agentfullname"
}

unload(){
    agentname "$1"
    agentlabel
    local domain rc
    domain="$(launchctlDomain)"
    launchctl bootout "$domain" "$agentfullname"
    rc=$?
    launchctl disable "$domain/$agentLabel" >/dev/null 2>&1 || true
    return "$rc"
}

reload(){
    agentname "$1"
    agentlabel
    local domain
    domain="$(launchctlDomain)"
    launchctl bootout "$domain" "$agentfullname" >/dev/null 2>&1
    launchctl enable "$domain/$agentLabel" >/dev/null 2>&1 || true
    launchctl bootstrap "$domain" "$agentfullname"
}

start(){
    agentname "$1"
    agentlabel
    launchctl start "$agentLabel"
}

stop(){
    agentname "$1"
    agentlabel
    launchctl stop "$agentLabel"
}

# 列出 LaunchAgent plist，并标记加载、运行和 PID 状态。
list(){
    local plist name label
    if [ ! -d "$agentPath" ];then
        echo "No LaunchAgents directory: $agentPath"
        return 0
    fi

    printLaunchStatusHeader
    for plist in "$agentPath"/*.plist;do
        if [ ! -e "$plist" ];then
            echo "No plist files in $agentPath"
            return 0
        fi

        name="$(basename "$plist")"
        label="$(agentLabelFromFile "$plist")"
        setLaunchStatus "$label"
        printLaunchStatusRow "$label" "$name"
    done
}

# 查看单个 LaunchAgent plist 的加载、运行和 PID 状态。
status(){
    agentname "$1"
    ensureAgentFile
    local name label
    name="$(basename "$agentfullname")"
    label="$(agentLabelFromFile "$agentfullname")"
    setLaunchStatus "$label"
    printLaunchStatusHeader
    printLaunchStatusRow "$label" "$name"
}

# 新建基础 LaunchAgent plist，默认 ProgramArguments 使用安全占位命令。
new(){
    agentname "$1"
    ensureAgentPath
    ensureNewAgentFile
    local label editor answer
    label="$(defaultAgentLabel)"
    keepNewTmpfile=0
    newTmpfile="$(mktemp -t lctl)"
    trap cleanupNewTmpfile EXIT
    if [ -z "$newTmpfile" ];then
        echo "${red}Failed to create temp plist file.${reset}"
        exit 1
    fi
    if ! cat > "$newTmpfile" <<EOF2
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Label: launchd job 的唯一标识，通常和文件名保持一致。 -->
    <key>Label</key>
    <string>$label</string>

    <!-- ProgramArguments: 要执行的命令和参数；第一个 string 必须是可执行文件路径。 -->
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/true</string>
    </array>

    <!-- RunAtLoad: load 后是否立即执行一次。 -->
    <key>RunAtLoad</key>
    <false/>

    <!-- KeepAlive: 进程退出后是否自动重启；常驻服务可改为 true 或 dict。 -->
    <key>KeepAlive</key>
    <false/>

    <!-- StartInterval: 按秒重复执行，适合简单周期任务；示例为每 300 秒执行一次。 -->
    <!--
    <key>StartInterval</key>
    <integer>300</integer>
    -->

    <!-- StartCalendarInterval: 按固定时间执行，适合定时任务；示例为每天 09:30 执行。 -->
    <!--
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>
    -->

    <!-- WatchPaths: 监听文件或目录变化后执行，路径应使用绝对路径。 -->
    <!--
    <key>WatchPaths</key>
    <array>
        <string>/path/to/watch</string>
    </array>
    -->

    <!-- QueueDirectories: 目录内存在待处理文件时执行，适合消费队列目录。 -->
    <!--
    <key>QueueDirectories</key>
    <array>
        <string>/path/to/queue</string>
    </array>
    -->

    <!-- StandardOutPath: 标准输出日志路径，建议放到用户可写目录。 -->
    <!--
    <key>StandardOutPath</key>
    <string>/tmp/$label.out.log</string>
    -->

    <!-- StandardErrorPath: 标准错误日志路径，建议和 StandardOutPath 分开。 -->
    <!--
    <key>StandardErrorPath</key>
    <string>/tmp/$label.err.log</string>
    -->

    <!-- WorkingDirectory: 任务运行时的工作目录，适合依赖相对路径的脚本。 -->
    <!--
    <key>WorkingDirectory</key>
    <string>$home</string>
    -->

    <!-- EnvironmentVariables: 任务运行时注入的环境变量，适合补充 PATH 或配置项。 -->
    <!--
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
    -->
</dict>
</plist>
EOF2
    then
        echo "${red}Failed to write temp plist file: $newTmpfile${reset}"
        exit 1
    fi

    editor="vi"
    if command -v vim >/dev/null 2>&1;then
        editor="vim"
    fi
    if ! "$editor" "$newTmpfile";then
        echo "Canceled."
        exit 1
    fi

    if ! plutil -lint "$newTmpfile" >/dev/null;then
        keepNewTmpfile=1
        echo "${red}Invalid plist, not saved to LaunchAgents.${reset}"
        echo "Temp file kept: $newTmpfile"
        exit 1
    fi

    echo -n "Save to $agentfullname? [y/N] "
    read -r answer
    case "$answer" in
        y|Y|yes|YES)
            ensureNewAgentFile
            if ! /bin/cp "$newTmpfile" "$agentfullname";then
                keepNewTmpfile=1
                echo "${red}Failed to save: $agentfullname${reset}"
                echo "Temp file kept: $newTmpfile"
                exit 1
            fi
            if ! chmod 644 "$agentfullname";then
                keepNewTmpfile=1
                echo "${red}Failed to chmod: $agentfullname${reset}"
                /bin/rm -f "$agentfullname"
                echo "Temp file kept: $newTmpfile"
                exit 1
            fi
            echo "Created: $agentfullname"
            ;;
        *)
            echo "Canceled."
            exit 1
            ;;
    esac
}

# 复制已有 LaunchAgent plist，并将 Label 更新为目标名称。
dump(){
    agentname "$1"
    local src="$agentfullname"
    ensureAgentFile

    agentname "$2"
    local dst="$agentfullname"
    ensureNewAgentFile

    if ! /bin/cp "$src" "$dst";then
        echo "${red}Failed to copy: $src -> $dst${reset}"
        exit 1
    fi
    if ! /usr/libexec/PlistBuddy -c "Set :Label $(defaultAgentLabel)" "$dst" >/dev/null 2>&1;then
        echo "${red}Failed to update Label: $dst${reset}"
        /bin/rm -f "$dst"
        exit 1
    fi
    echo "Copied: $src -> $dst"
}

rm(){
    agentname "$1"
    ensureAgentFile
    echo -n "Remove $agentfullname? [y/N] "
    read -r answer
    case "$answer" in
        y|Y|yes|YES)
            /bin/rm -f "$agentfullname"
            ;;
        *)
            echo "Canceled."
            ;;
    esac
}

edit(){
    agentname "$1"
    ensureAgentFile
    editor="vi"
    if command -v vim >/dev/null 2>&1;then
        editor="vim"
    fi
    "$editor" "$agentfullname"
}

em(){
    editor="vi"
    if command -v vim >/dev/null 2>&1;then
        editor="vim"
    fi
    "$editor" "${BASH_SOURCE[0]}"
}



###############################################################################
# write your code above
###############################################################################
# 打印命令用法、参数说明和常见示例。
function help(){
    cat<<EOF2
Usage:
  $(basename "$0") ${bold}CMD${reset} [ARGS...]

${bold}Commands${reset}:
  help                         Show this help message
  list                         List plist files with loaded/running/PID status
  status NAME                  Show one plist loaded/running/PID status
  new NAME                     Create a plist from an editable template
  dump SRC_NAME DST_NAME       Copy an existing plist and update its Label
  edit NAME                    Edit an existing plist
  rm NAME                      Remove an existing plist after confirmation
  load NAME                    launchctl bootstrap the plist into current gui domain
  unload NAME                  launchctl bootout the plist from current gui domain
  reload NAME                  bootout, then bootstrap the plist
  start NAME                   Start the job by plist Label
  stop NAME                    Stop the job by plist Label
  em                           Edit this script

${bold}Examples${reset}:
  $(basename "$0") new com.example.agent
  $(basename "$0") dump com.eagle.sync-work com.example.agent
  $(basename "$0") edit com.example.agent
  $(basename "$0") status com.example.agent
  $(basename "$0") load com.example.agent

${bold}Notes${reset}:
  NAME can omit the .plist suffix.
  Files are managed under ~/Library/LaunchAgents.
  new opens a temp plist first and saves only after you confirm with y/yes.
EOF2
}
function loadENV(){
    if [ -z "$INIT_HTTP_PROXY" ];then
        echo "INIT_HTTP_PROXY is empty"
        echo -n "Enter http proxy: (if you need) "
        read -r INIT_HTTP_PROXY
    fi
    if [ -n "$INIT_HTTP_PROXY" ];then
        echo "set http proxy to $INIT_HTTP_PROXY"
        export http_proxy=$INIT_HTTP_PROXY
        export https_proxy=$INIT_HTTP_PROXY
        export HTTP_PROXY=$INIT_HTTP_PROXY
        export HTTPS_PROXY=$INIT_HTTP_PROXY
        git config --global http.proxy "$INIT_HTTP_PROXY"
        git config --global https.proxy "$INIT_HTTP_PROXY"
    else
        echo "No use http proxy"
    fi
}

function unloadENV(){
    if [ -n "$https_proxy" ];then
        unset http_proxy
        unset https_proxy
        unset HTTP_PROXY
        unset HTTPS_PROXY
        git config --global --unset-all http.proxy
        git config --global --unset-all https.proxy
    fi
}


case "$1" in
     ""|-h|--help|help)
        help
        ;;
    load|unload|reload|start|stop|list|status|new|dump|rm|edit|em)
        "$@"
        ;;
    *)
        echo "Unknown cmd: $1"
        help
        exit 1
esac
