# Shared SSH config for all machines.
# This file documents the generated ~/.ssh/config layout used by scripts/zsh.sh.
# The live wrapper written to ~/.ssh/config uses the current repo path.
# Keep machine-specific hosts, agents, and network-specific settings in one of:
#   - <repo>/softlinks/sshconfig.local
#   - ~/.ssh/config.local
#
# Include directives must appear before any Host blocks.
# Local includes come first so they can override shared aliases when needed.
Include __INIT_REPO_ROOT__/softlinks/sshconfig.local
Include ~/.ssh/config.local
Include __INIT_REPO_ROOT__/softlinks/sshconfig.shared
