# Shared SSH config for all machines.
# Keep machine-specific hosts, agents, and network-specific settings in one of:
#   - ~/.local/apps/init/softlinks/sshconfig.local
#   - ~/.ssh/config.local
#
# Include directives must appear before any Host blocks.
# Local includes come first so they can override shared aliases when needed.
Include ~/.local/apps/init/softlinks/sshconfig.local
Include ~/.ssh/config.local
Include ~/.local/apps/init/softlinks/sshconfig.shared
