# Machine-local SSH config.
# Copy this file to softlinks/sshconfig.local or ~/.ssh/config.local on each machine.
# Put internal hosts, network-specific aliases, and agent/socket config here.

# OrbStack integration example.
# Include ~/.orbstack/ssh/config

# 1Password SSH agent example for macOS.
# Match exec "uname | grep -q Darwin"
#     IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# Example local-only hosts.
# Host my-devbox
#     HostName 10.0.0.10
#     User your-user
#     Port 22

# Host office-jump
#     HostName 192.168.1.10
#     User your-user

# If a host should be shared across all machines, add it to softlinks/sshconfig.shared instead.
