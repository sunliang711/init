nmap <silent> <leader>gk <Plug>(GitGutterPrevHunk)
nmap <silent> <leader>gp <Plug>(GitGutterPreviewHunk)
nmap <silent> <leader>gr <Plug>(GitGutterUndoHunk)
xmap <silent> <leader>gr <Plug>(GitGutterUndoHunk)
nmap <silent> <leader>gs <Plug>(GitGutterStageHunk)
xmap <silent> <leader>gs <Plug>(GitGutterStageHunk)
nnoremap <silent> <leader>go :GFiles?<CR>
nnoremap <silent> <leader>gb :Git branch<CR>
nnoremap <silent> <leader>gc :Commits<CR>
nnoremap <silent> <leader>gg :call <SID>OpenLazyGit()<CR>

nmap <silent> <leader>/ gcc
xmap <silent> <leader>/ gc
nmap gw <Plug>(easymotion-w)
nmap gl <Plug>(easymotion-lineforward)
nmap gp <Plug>(easymotion-sn)

nnoremap <silent> <leader>xl :lopen<CR>
nnoremap <silent> <leader>xq :copen<CR>

nnoremap <c-h> <c-w>h
nnoremap <c-l> <c-w>l
nnoremap <c-j> <c-w>j
nnoremap <c-k> <c-w>k
nnoremap <up> :resize +2<CR>
nnoremap <down> :resize -2<CR>
nnoremap <left> :vertical resize -2<CR>
nnoremap <right> :vertical resize +2<CR>
