" 打开 which-key 菜单；插件缺失时避免普通 leader 按键报错。
function! s:ShowWhichKey(visual) abort
    if a:visual && exists(':WhichKeyVisual')
        WhichKeyVisual ','
    elseif !a:visual && exists(':WhichKey')
        WhichKey ','
    else
        echoerr 'vim-which-key is not installed'
    endif
endfunction

" 打开健康检查；Vim 缺少 Neovim checkhealth 时回退到版本信息。
function! s:CheckHealth() abort
    if exists(':checkhealth')
        checkhealth
    elseif exists(':CheckHealth')
        CheckHealth
    else
        version
    endif
endfunction

