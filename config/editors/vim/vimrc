" 检测 fzf.vim 的 autoload 文件，避免 exists('*fzf#vim#...') 误判未安装。
function! s:HasFzfVim() abort
    return !empty(globpath(&runtimepath, 'autoload/fzf/vim.vim'))
endfunction

" 根据隐藏文件和 ignore 开关刷新 fzf 默认文件搜索命令。
function! s:RefreshFzfDefaultCommand() abort
    if !executable('rg')
        return
    endif

    let cmd = 'rg --files --color=never --glob "!.git"'
    if get(g:, 'vim_fzf_search_hidden', 0)
        let cmd .= ' --hidden'
    endif
    if get(g:, 'vim_fzf_search_no_ignore', 0)
        let cmd .= ' --no-ignore'
    endif
    let $FZF_DEFAULT_COMMAND = cmd
endfunction

" 使用 fzf.vim 打开文件搜索，缺少插件时给出明确提示。
function! s:FzfFindFiles(with_preview) abort
    if !s:HasFzfVim()
        echoerr 'fzf.vim is not installed'
        return
    endif

    call s:RefreshFzfDefaultCommand()
    if a:with_preview
        call fzf#vim#files('', fzf#vim#with_preview(), 0)
    else
        call fzf#vim#files('', {}, 0)
    endif
endfunction

" 使用 fzf.vim 的 live grep，在 fzf 输入框中输入 pattern。
function! s:FzfTextSearch() abort
    if !s:HasFzfVim()
        echoerr 'fzf.vim is not installed'
        return
    endif
    if !executable('rg')
        echoerr 'ripgrep is not installed'
        return
    endif

    let cmd = 'rg --column --line-number --no-heading --color=always --smart-case'
    if get(g:, 'vim_fzf_search_hidden', 0)
        let cmd .= ' --hidden --glob "!.git"'
    endif
    if get(g:, 'vim_fzf_search_no_ignore', 0)
        let cmd .= ' --no-ignore'
    endif
    let cmd .= ' -- '

    call fzf#vim#grep2(cmd, '', fzf#vim#with_preview(), 0)
endfunction

" 切换 fzf 文件搜索是否包含隐藏文件。
function! s:ToggleFzfHidden() abort
    let g:vim_fzf_search_hidden = !get(g:, 'vim_fzf_search_hidden', 0)
    call s:RefreshFzfDefaultCommand()
    echo g:vim_fzf_search_hidden ? 'fzf hidden files shown' : 'fzf hidden files hidden'
endfunction

" 切换 fzf 文件搜索是否忽略 .gitignore。
function! s:ToggleFzfNoIgnore() abort
    let g:vim_fzf_search_no_ignore = !get(g:, 'vim_fzf_search_no_ignore', 0)
    call s:RefreshFzfDefaultCommand()
    echo g:vim_fzf_search_no_ignore ? 'fzf gitignored files shown' : 'fzf gitignored files hidden'
endfunction

" 打开 lazygit；未安装 lazygit 时回退到 fugitive 的 Git 状态窗口。
function! s:OpenLazyGit() abort
    if executable('lazygit') && exists(':terminal')
        bel terminal lazygit
    elseif exists(':Git')
        Git
    else
        echoerr 'lazygit or vim-fugitive is not installed'
    endif
endfunction

