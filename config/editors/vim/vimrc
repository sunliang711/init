                \ 'c': 'cursorcolumn',
                \ 'd': 'fzf-hidden',
                \ 'g': 'fzf-no-ignore',
                \ 's': 'spell',
                \ 'D': 'background-dark',
                \ 'L': 'background-light',
                \ 'h': 'search-highlight',
                \ }
    let g:which_key_map.b = {
