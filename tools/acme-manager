# 解析 renew 子命令参数，支持单任务续期和 enabled 任务批量续期。
cmd_renew() {
    local id=""
    local renew_all=0
    local force=0
    local file=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --all)
                renew_all=1
                shift
                ;;
            --force)
                force=1
                shift
                ;;
            --acme-home)
                [ $# -ge 2 ] || die "missing value for --acme-home"
                ACME_HOME="$2"
                refresh_manager_paths
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                if [ -n "${id}" ]; then
                    die "renew accepts one task id or --all"
                fi
                id="$1"
                shift
                ;;
        esac
    done

    require_root
    require_linux

    if [ "${renew_all}" -eq 1 ]; then
        [ -z "${id}" ] || die "renew accepts one task id or --all"
        if [ ! -d "${TASKS_DIR}" ]; then
            log "no tasks found"
            return 0
        fi

        for file in "${TASKS_DIR}"/*.task; do
            [ -e "${file}" ] || continue
            load_task "$(basename "${file}" .task)"
            if [ "${TASK_STATUS}" = "disabled" ]; then
                log "skip disabled task ${TASK_ID}"
                continue
            fi
            renew_current_task "${force}"
        done
        return 0
    fi

    [ -n "${id}" ] || die "task id or --all is required"
    load_task "${id}"

    if [ "${TASK_STATUS}" = "disabled" ]; then
        log "task ${TASK_ID} is disabled, running manual renew anyway"
    fi

    renew_current_task "${force}"
}

