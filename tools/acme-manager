                domain_list="$(normalize_cert_spec "$2")"
                shift 2
                ;;
            --install-name)
                [ $# -ge 2 ] || die "missing value for --install-name"
                TASK_INSTALL_NAME="$2"
                shift 2
                ;;
            --config-home)
                [ $# -ge 2 ] || die "missing value for --config-home"
                config_home="$2"
                shift 2
                ;;
            --cert-dir)
                [ $# -ge 2 ] || die "missing value for --cert-dir"
                CERT_DIR="$2"
                shift 2
                ;;
            --acme-home)
                [ $# -ge 2 ] || die "missing value for --acme-home"
                ACME_HOME="$2"
                refresh_manager_paths
                shift 2
                ;;
            --key-length)
                [ $# -ge 2 ] || die "missing value for --key-length"
                KEY_LENGTH="$2"
                shift 2
                ;;
            --reloadcmd)
                [ $# -ge 2 ] || die "missing value for --reloadcmd"
                RELOAD_CMD="$2"
                shift 2
                ;;
            --status)
                [ $# -ge 2 ] || die "missing value for --status"
                TASK_STATUS="$2"
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                die "unknown import argument: $1"
                ;;
        esac
    done

    [ -n "${TASK_ID}" ] || die "--id is required"
    [ -n "${primary_domain}" ] || die "--domain is required"
    validate_task_id "${TASK_ID}"
    validate_domain_label "${primary_domain}"

    if task_exists "${TASK_ID}"; then
        die "task already exists: ${TASK_ID}"
    fi

    if [ -z "${domain_list}" ]; then
        domain_list="${primary_domain}"
    fi
    validate_domain_spec "${domain_list}"

    if [ -z "${TASK_INSTALL_NAME}" ]; then
        TASK_INSTALL_NAME="${TASK_ID}"
    fi
    validate_install_name "${TASK_INSTALL_NAME}"

    if [ -z "${config_home}" ]; then
        config_home="${ACME_HOME}"
    fi
    require_absolute_path "--config-home" "${config_home}"
    require_absolute_path "--cert-dir" "${CERT_DIR}"

    case "${TASK_STATUS}" in
        enabled|disabled)
            ;;
