    printf '%-5s %s\n' "${status}" "${message}"
}

# 执行环境和任务健康检查，不主动修改系统状态。
cmd_doctor() {
    local file=""
    local id=""
    local task_count=0

    while [ $# -gt 0 ]; do
        case "$1" in
            --acme-home)
                [ $# -ge 2 ] || die "missing value for --acme-home"
                ACME_HOME="$2"
                refresh_manager_paths
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                die "unknown doctor argument: $1"
                ;;
        esac
    done

    if [ "$(uname -s)" = "Linux" ]; then
        doctor_check "OK" "platform is Linux"
    else
        doctor_check "FAIL" "platform is not Linux"
    fi

    if [ "${EUID}" -eq 0 ]; then
        doctor_check "OK" "running as root"
    else
        doctor_check "WARN" "not running as root"
    fi

    if [ -x "$(acme_bin)" ]; then
        doctor_check "OK" "acme.sh found: $(acme_bin)"
    else
        doctor_check "FAIL" "acme.sh not found: $(acme_bin)"
    fi

    if [ -d "${TASKS_DIR}" ]; then
        doctor_check "OK" "tasks dir exists: ${TASKS_DIR}"
    else
        doctor_check "WARN" "tasks dir not found: ${TASKS_DIR}"
    fi

    if [ -x "${DEFAULT_RELOAD_CMD}" ]; then
        doctor_check "OK" "default reload hook is executable: ${DEFAULT_RELOAD_CMD}"
    else
        doctor_check "WARN" "default reload hook is not executable: ${DEFAULT_RELOAD_CMD}"
    fi

    if [ -d "${TASKS_DIR}" ]; then
        for file in "${TASKS_DIR}"/*.task; do
            [ -e "${file}" ] || continue
            id="$(basename "${file}" .task)"
            load_task "${id}"
            task_count=$((task_count + 1))

            if [ -e "$(task_source_cert_file)" ]; then
                doctor_check "OK" "task ${TASK_ID} source cert exists"
            else
                doctor_check "FAIL" "task ${TASK_ID} source cert missing: $(task_source_cert_file)"
            fi
        done
    fi

    doctor_check "OK" "managed task count: ${task_count}"
}

# 解析预置全局参数，然后分派到具体子命令。
main() {
    local command=""

    refresh_manager_paths

    while [ $# -gt 0 ]; do
        case "$1" in
            --acme-home)
                [ $# -ge 2 ] || die "missing value for --acme-home"
                ACME_HOME="$2"
                refresh_manager_paths
                shift 2
                ;;
            --cert-dir)
                [ $# -ge 2 ] || die "missing value for --cert-dir"
                CERT_DIR="$2"
                shift 2
                ;;
            --key-length)
                [ $# -ge 2 ] || die "missing value for --key-length"
                KEY_LENGTH="$2"
                shift 2
                ;;
            --reloadcmd)
                [ $# -ge 2 ] || die "missing value for --reloadcmd"
                RELOAD_CMD="$2"
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            install|issue|list|show|renew|deploy|disable|enable|remove|revoke|import|rename|doctor)
                command="$1"
                shift
                case "${command}" in
                    install)
                        cmd_install "$@"
                        ;;
                    issue)
                        cmd_issue "$@"
                        ;;
                    list)
                        cmd_list "$@"
                        ;;
                    show)
                        cmd_show "$@"
                        ;;
                    renew)
                        cmd_renew "$@"
                        ;;
                    deploy)
                        cmd_deploy "$@"
                        ;;
                    disable)
                        cmd_set_status "disabled" "$@"
                        ;;
                    enable)
                        cmd_set_status "enabled" "$@"
                        ;;
                    remove)
                        cmd_remove "$@"
                        ;;
                    revoke)
                        cmd_revoke "$@"
                        ;;
                    import)
                        cmd_import "$@"
                        ;;
                    rename)
                        cmd_rename "$@"
                        ;;
                    doctor)
                        cmd_doctor "$@"
                        ;;
                esac
                return 0
                ;;
            *)
                die "unknown command or global argument: $1"
                ;;
        esac
    done

    usage
    exit 1
}

main "$@"
