# 判断任务域名列表是否包含指定域名，用于 list 过滤。
task_matches_domain() {
    local filter_domain="${1:?missing filter domain}"
    local -a domains=()
    local domain=""

    IFS=',' read -r -a domains <<< "${TASK_DOMAINS}"
    for domain in "${domains[@]}"; do
        if [ "${domain}" = "${filter_domain}" ]; then
            return 0
        fi
    done

    return 1
}

# 解析 list 子命令参数并输出任务表。
cmd_list() {
    local filter_domain=""
    local filter_status=""
    local file=""
    local id=""
    local count=0

    while [ $# -gt 0 ]; do
        case "$1" in
            --domain)
                [ $# -ge 2 ] || die "missing value for --domain"
                filter_domain="$2"
                shift 2
                ;;
            --status)
                [ $# -ge 2 ] || die "missing value for --status"
                filter_status="$2"
                shift 2
                ;;
            --acme-home)
                [ $# -ge 2 ] || die "missing value for --acme-home"
                ACME_HOME="$2"
                refresh_manager_paths
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                die "unknown list argument: $1"
                ;;
        esac
    done

    case "${filter_status}" in
        ""|enabled|disabled)
            ;;
        *)
            die "--status must be enabled or disabled"
            ;;
    esac

    printf '%-24s %-24s %-8s %-9s %-24s %s\n' "ID" "PRIMARY" "KEY" "STATUS" "INSTALL_NAME" "DOMAINS"
    if [ -d "${TASKS_DIR}" ]; then
        for file in "${TASKS_DIR}"/*.task; do
            [ -e "${file}" ] || continue
            id="$(basename "${file}" .task)"
            load_task "${id}"

            if [ -n "${filter_domain}" ] && ! task_matches_domain "${filter_domain}"; then
                continue
            fi

            if [ -n "${filter_status}" ] && [ "${TASK_STATUS}" != "${filter_status}" ]; then
                continue
            fi

            printf '%-24s %-24s %-8s %-9s %-24s %s\n' \
                "${TASK_ID}" \
                "${TASK_PRIMARY_DOMAIN}" \
                "${TASK_KEY_LENGTH}" \
                "${TASK_STATUS}" \
                "${TASK_INSTALL_NAME}" \
                "${TASK_DOMAINS}"
            count=$((count + 1))
        done
    fi

    if [ "${count}" -eq 0 ]; then
        log "no tasks found"
    fi
}

