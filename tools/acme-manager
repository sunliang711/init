    TASK_KEY_LENGTH="${KEY_LENGTH}"
    TASK_RELOAD_CMD="${RELOAD_CMD}"
    TASK_CONFIG_HOME="${config_home}"

    if [ ! -e "$(task_source_cert_file)" ]; then
        die "source cert not found for import: $(task_source_cert_file)"
    fi

    ensure_manager_dirs
    write_task_file
    log "task ${TASK_ID} imported"
}

# 解析 rename 子命令参数并修改任务 ID。
cmd_rename() {
    local old_id=""
    local new_id=""
    local old_file=""
    local old_config_home=""
    local new_config_home=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --acme-home)
                [ $# -ge 2 ] || die "missing value for --acme-home"
                ACME_HOME="$2"
                refresh_manager_paths
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                if [ -z "${old_id}" ]; then
                    old_id="$1"
                elif [ -z "${new_id}" ]; then
                    new_id="$1"
                else
                    die "rename accepts old-id and new-id"
                fi
                shift
                ;;
        esac
    done

    [ -n "${old_id}" ] || die "old task id is required"
    [ -n "${new_id}" ] || die "new task id is required"
    validate_task_id "${new_id}"

    if task_exists "${new_id}"; then
        die "task already exists: ${new_id}"
    fi

    load_task "${old_id}"
    old_file="$(task_file_path "${TASK_ID}")"
    old_config_home="${TASK_CONFIG_HOME}"

    case "${old_config_home}" in
        "${RUNTIME_DIR}/${old_id}")
            new_config_home="${RUNTIME_DIR}/${new_id}"
            if [ -e "${new_config_home}" ]; then
                die "target config home already exists: ${new_config_home}"
            fi
            if [ -e "${old_config_home}" ]; then
                mv "${old_config_home}" "${new_config_home}"
            fi
            TASK_CONFIG_HOME="${new_config_home}"
            ;;
    esac

    TASK_ID="${new_id}"
    write_task_file
    safe_remove_path "${old_file}"
    log "task ${old_id} renamed to ${new_id}"
}

