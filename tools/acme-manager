# 安全删除指定路径，拒绝空路径、根目录和关键系统目录。
safe_remove_path() {
    local path="${1:?missing path}"

    case "${path}" in
        ""|"/"|"/etc"|"/etc/"|"/root"|"/root/"|"/home"|"/home/"|"/usr"|"/usr/"|"/var"|"/var/")
            die "refuse to remove unsafe path: ${path}"
            ;;
    esac

    if [ -e "${path}" ] || [ -L "${path}" ]; then
        rm -rf -- "${path}"
    fi
}

# 删除当前任务安装到业务目录的证书文件。
remove_installed_files() {
    safe_remove_path "${TASK_CERT_DIR}/${TASK_INSTALL_NAME}.cer"
    safe_remove_path "${TASK_CERT_DIR}/${TASK_INSTALL_NAME}.key"
    safe_remove_path "${TASK_CERT_DIR}/${TASK_INSTALL_NAME}.pem"
}

# 删除当前任务的内部运行目录，外部导入的 config home 默认保留。
remove_task_runtime() {
    case "${TASK_CONFIG_HOME}" in
        "${RUNTIME_DIR}/"*)
            safe_remove_path "${TASK_CONFIG_HOME}"
            ;;
        *)
            log "preserve external config home for task ${TASK_ID}: ${TASK_CONFIG_HOME}"
            ;;
    esac
}

# 解析 remove 子命令参数并删除任务记录，可选删除已安装证书文件。
cmd_remove() {
    local id=""
    local purge_installed_files=0
    local file=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --purge-installed-files)
                purge_installed_files=1
                shift
                ;;
            --acme-home)
                [ $# -ge 2 ] || die "missing value for --acme-home"
                ACME_HOME="$2"
                refresh_manager_paths
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                if [ -n "${id}" ]; then
                    die "remove accepts exactly one task id"
                fi
                id="$1"
                shift
                ;;
        esac
    done

    [ -n "${id}" ] || die "task id is required"
    require_root
    require_linux
    load_task "${id}"

    if command_exists "$(acme_bin)"; then
        if ! task_acme_cmd --remove -d "${TASK_PRIMARY_DOMAIN}" --keylength "${TASK_KEY_LENGTH}"; then
            log "acme remove failed for task ${TASK_ID}, continue removing manager state"
        fi
    fi

    if [ "${purge_installed_files}" -eq 1 ]; then
        remove_installed_files
    fi

    remove_task_runtime
    file="$(task_file_path "${TASK_ID}")"
    safe_remove_path "${file}"
    log "task ${TASK_ID} removed"
}

