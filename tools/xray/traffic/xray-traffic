def command_edit_config(args: argparse.Namespace) -> int:
    """打开配置文件供用户直接编辑，适用于运维调整实例、路径和保留期。"""

    config_file = resolve_config_file_path(args)
    ensure_config_file_exists(config_file)
    backup_path = backup_config_file(config_file)
    editor_command = resolve_editor_command()

    result = subprocess.run([*editor_command, str(config_file)], check=False)
    if result.returncode != 0:
        raise CliError(f"editor exited with status {result.returncode}; backup kept at {backup_path}")

    try:
        config = resolve_config(args)
        validate_config(config)
    except CliError as exc:
        raise CliError(f"config validation failed; backup kept at {backup_path}: {exc}") from exc

    logging.info("Config validation passed")
    return command_check_config(argparse.Namespace(), config)


