def parse_env_file(path: Path) -> Dict[str, str]:
    """读取简单 KEY=VALUE 配置文件，适用于 systemd EnvironmentFile 兼容配置。"""

    values: Dict[str, str] = {}
    if not path.exists():
        return values

    with path.open("r", encoding="utf-8") as config_file:
        for raw_line in config_file:
            line = raw_line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, value = line.split("=", 1)
            key = key.strip()
            value = value.strip().strip('"').strip("'")
            if key:
                values[key] = value
    return values


def pick_config_value(
    arg_value: Optional[Any],
    env_values: Dict[str, str],
    file_values: Dict[str, str],
    env_name: str,
    default: Any,
) -> Any:
    """按命令行、环境变量、配置文件、默认值的顺序选择配置值。"""

    if arg_value is not None:
        return arg_value
    if env_name in env_values:
        return env_values[env_name]
    if env_name in file_values:
        return file_values[env_name]
    return default


def parse_int_config_value(value: Any, config_name: str) -> int:
    """解析整数配置项，适用于将配置错误统一转换为 CliError。"""

    try:
        return int(value)
    except (TypeError, ValueError) as exc:
        raise CliError(f"{config_name} must be an integer: {value}") from exc


def resolve_config_file_path(args: argparse.Namespace) -> Path:
    """解析配置文件路径，适用于编辑配置和完整配置加载前定位文件。"""

    config_file_value = args.config or os.environ.get("XRAY_TRAFFIC_CONFIG")
    return Path(config_file_value) if config_file_value else DEFAULT_CONFIG_FILE


def default_config_text(config_file: Path) -> str:
    """生成默认配置内容，适用于 edit config 首次创建配置文件。"""

    del config_file
    return "\n".join(
        [
            "XRAY_TRAFFIC_INSTANCES=default=127.0.0.1:18080",
            f"XRAY_BIN={DEFAULT_XRAY_BIN}",
            f"XRAY_TRAFFIC_DB={DEFAULT_DB_PATH}",
            f"XRAY_TRAFFIC_RETENTION_DAYS={DEFAULT_RETENTION_DAYS}",
            "XRAY_TRAFFIC_TIMEZONE=Asia/Shanghai",
            f"XRAY_TRAFFIC_TIMEOUT_SECONDS={DEFAULT_TIMEOUT_SECONDS}",
            "",
        ]
    )


def ensure_config_file_exists(config_file: Path) -> None:
    """确保配置文件存在，适用于 edit config 打开编辑器前准备目标文件。"""

    if config_file.exists():
        return
    config_file.parent.mkdir(parents=True, exist_ok=True)
    config_file.write_text(default_config_text(config_file), encoding="utf-8")
    config_file.chmod(0o600)
    logging.info("Config file created: %s", config_file)


def backup_config_file(config_file: Path) -> Path:
    """备份配置文件，适用于 edit config 编辑前保留可回滚版本。"""

    timestamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    backup_path = config_file.with_name(f"{config_file.name}.bak.{timestamp}")
    suffix = 1
    while backup_path.exists():
        backup_path = config_file.with_name(f"{config_file.name}.bak.{timestamp}.{suffix}")
        suffix += 1
    shutil.copy2(config_file, backup_path)
    logging.info("Config backup created: %s", backup_path)
    return backup_path


def editor_command_exists(command_name: str) -> bool:
    """判断编辑器命令是否可执行，适用于选择 $EDITOR 或默认编辑器。"""

    if "/" in command_name:
        return Path(command_name).is_file() and os.access(command_name, os.X_OK)
    return shutil.which(command_name) is not None


def resolve_editor_command() -> List[str]:
    """选择可用编辑器命令，适用于 edit config 打开配置文件。"""

    candidates: List[List[str]] = []
    editor_value = os.environ.get("EDITOR", "").strip()
    if editor_value:
        try:
            candidates.append(shlex.split(editor_value))
        except ValueError as exc:
            raise CliError(f"invalid EDITOR value: {editor_value}") from exc
    candidates.extend([[name] for name in ("vim", "vi", "nano")])

    for command in candidates:
        if command and editor_command_exists(command[0]):
            return command
    raise CliError("no editor found; set EDITOR or install vim, vi, or nano")


def parse_instances(raw_value: str) -> Tuple[InstanceConfig, ...]:
    """解析 XRAY_TRAFFIC_INSTANCES，适用于构建多实例运行配置。"""

    instances: List[InstanceConfig] = []
    seen_names: set[str] = set()
    for raw_item in raw_value.split(","):
        item = raw_item.strip()
        if not item:
            continue
        if "=" not in item:
            raise CliError(f"invalid instance entry: {item}")
        name, server = item.split("=", 1)
        name = name.strip()
        server = server.strip()
        if not name:
            raise CliError("instance name must not be empty")
        if name == ALL_INSTANCE:
            raise CliError("instance name ALL is reserved")
        if not INSTANCE_NAME_RE.fullmatch(name):
            raise CliError(f"invalid instance name: {name}")
        if not server:
            raise CliError(f"server must not be empty for instance: {name}")
        if name in seen_names:
            raise CliError(f"duplicate instance name: {name}")
        seen_names.add(name)
        instances.append(InstanceConfig(name=name, server=server))

    if not instances:
        raise CliError("XRAY_TRAFFIC_INSTANCES must define at least one instance")
    return tuple(instances)


def resolve_config(args: argparse.Namespace) -> AppConfig:
    """解析全局配置，适用于所有子命令执行前统一生成运行参数。"""

    env_values = dict(os.environ)
    config_file = resolve_config_file_path(args)
    file_values = parse_env_file(config_file)
    if config_file.exists() and "XRAY_TRAFFIC_INSTANCES" not in file_values:
        raise CliError(
            "config file is missing XRAY_TRAFFIC_INSTANCES; update the config file before running: "
            f"{config_file}"
        )

    retention_days = parse_int_config_value(
        pick_config_value(
            args.retention_days,
            env_values,
            file_values,
            "XRAY_TRAFFIC_RETENTION_DAYS",
            DEFAULT_RETENTION_DAYS,
        ),
        "XRAY_TRAFFIC_RETENTION_DAYS",
    )
    timeout_seconds = parse_int_config_value(
        pick_config_value(
            args.timeout,
            env_values,
            file_values,
            "XRAY_TRAFFIC_TIMEOUT_SECONDS",
            DEFAULT_TIMEOUT_SECONDS,
        ),
        "XRAY_TRAFFIC_TIMEOUT_SECONDS",
    )
    if "XRAY_TRAFFIC_INSTANCES" in env_values:
        raw_instances = env_values["XRAY_TRAFFIC_INSTANCES"]
    elif "XRAY_TRAFFIC_INSTANCES" in file_values:
        raw_instances = file_values["XRAY_TRAFFIC_INSTANCES"]
    else:
        raise CliError(
            "XRAY_TRAFFIC_INSTANCES must be configured via environment or config file: "
            f"{config_file}"
        )

    if retention_days <= 0:
        raise CliError("retention days must be greater than 0")
    if timeout_seconds <= 0:
        raise CliError("timeout seconds must be greater than 0")

    return AppConfig(
        config_file=config_file,
        instances=parse_instances(raw_instances),
        xray_bin=str(
            pick_config_value(args.xray_bin, env_values, file_values, "XRAY_BIN", DEFAULT_XRAY_BIN)
        ),
        db_path=Path(
            str(pick_config_value(args.db, env_values, file_values, "XRAY_TRAFFIC_DB", DEFAULT_DB_PATH))
        ),
        retention_days=retention_days,
        timezone_name=pick_config_value(
            args.timezone,
            env_values,
            file_values,
            "XRAY_TRAFFIC_TIMEZONE",
            None,
        ),
        timeout_seconds=timeout_seconds,
    )


def get_timezone(config: AppConfig) -> timezone:
    """返回配置指定时区；未配置时使用系统本地时区。"""

    if config.timezone_name:
        try:
            return ZoneInfo(config.timezone_name)
        except Exception as exc:
            raise CliError(f"invalid timezone: {config.timezone_name}") from exc
    local_tz = datetime.now().astimezone().tzinfo
    if local_tz is None:
        return timezone.utc
    return local_tz


def validate_config(config: AppConfig) -> None:
    """校验完整运行配置，适用于 check config 和 edit config 保存后检查。"""

    get_timezone(config)


def configure_logging(level: str) -> None:
    """初始化日志输出，适用于 systemd journal 和手工命令行执行。"""

    logging.basicConfig(
        level=getattr(logging, level.upper(), logging.INFO),
        format="%(levelname)s %(message)s",
    )


def format_available_instances(config: AppConfig) -> str:
    """格式化可用实例列表，适用于 --instance 缺失或非法时报错。"""

    lines = ["Available instances:", f"  {ALL_INSTANCE:<12} all configured instances"]
    for instance in config.instances:
        lines.append(f"  {instance.name:<12} {instance.server}")
    return "\n".join(lines)


def select_instances(config: AppConfig, instance_name: Optional[str]) -> Tuple[InstanceConfig, ...]:
    """根据 --instance 选择实例，适用于所有涉及实例的命令。"""

    if not instance_name:
        raise CliError(
            "--instance is required\n\n"
            f"{format_available_instances(config)}\n\n"
            f"Example:\n  xray-traffic show hourly --instance {config.instances[0].name}"
        )
    if instance_name == ALL_INSTANCE:
        return config.instances

    for instance in config.instances:
        if instance.name == instance_name:
            return (instance,)
    raise CliError(f"unknown instance: {instance_name}\n\n{format_available_instances(config)}")


def ensure_database(connection: sqlite3.Connection, db_path: Path) -> None:
    """创建 SQLite 表和索引；旧 schema 直接报错，避免不兼容数据混写。"""

    connection.execute("PRAGMA journal_mode=WAL")
    connection.execute("PRAGMA foreign_keys=ON")
    table_row = connection.execute(
        "SELECT name FROM sqlite_master WHERE type = 'table' AND name = 'traffic_records'"
    ).fetchone()
    if table_row is not None:
        table_info = connection.execute("PRAGMA table_info(traffic_records)").fetchall()
        columns = {str(row["name"]) for row in table_info}
        required_columns = {
            "instance",
            "server",
            "period",
            "start_ts",
            "end_ts",
            "start_time",
            "end_time",
            "scope",
            "name",
            "direction",
            "bytes",
            "created_at",
        }
        if not required_columns.issubset(columns):
            raise CliError(
                "existing database schema is incompatible; backup and remove old database: "
                f"{db_path}"
            )
        primary_key_columns = [
            str(row["name"])
            for row in sorted(table_info, key=lambda item: int(item["pk"]))
            if int(row["pk"]) > 0
        ]
        expected_primary_key = ["instance", "period", "start_ts", "scope", "name", "direction"]
        if primary_key_columns != expected_primary_key:
            raise CliError(
                "existing database primary key is incompatible; backup and remove old database: "
                f"{db_path}"
            )
    else:
        connection.execute(
            """
            CREATE TABLE traffic_records (
                instance TEXT NOT NULL,
                server TEXT NOT NULL,
                period TEXT NOT NULL,
                start_ts INTEGER NOT NULL,
                end_ts INTEGER NOT NULL,
                start_time TEXT NOT NULL,
                end_time TEXT NOT NULL,
                scope TEXT NOT NULL,
                name TEXT NOT NULL,
                direction TEXT NOT NULL,
                bytes INTEGER NOT NULL,
                created_at TEXT NOT NULL,
                PRIMARY KEY (instance, period, start_ts, scope, name, direction)
            )
            """
        )
    connection.execute(
        """
        CREATE INDEX IF NOT EXISTS idx_traffic_records_lookup
        ON traffic_records (period, instance, scope, name, start_ts)
        """
    )
    connection.execute(
        """
        CREATE TABLE IF NOT EXISTS metadata (
            key TEXT PRIMARY KEY,
            value TEXT NOT NULL
        )
        """
    )
    connection.commit()


@contextmanager
def database_lock(db_path: Path) -> Iterator[None]:
    """使用文件锁保护 SQLite 写入，避免定时任务并发写库。"""

    db_path.parent.mkdir(parents=True, exist_ok=True)
    lock_path = db_path.with_suffix(db_path.suffix + ".lock")
    with lock_path.open("w", encoding="utf-8") as lock_file:
        fcntl.flock(lock_file.fileno(), fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(lock_file.fileno(), fcntl.LOCK_UN)


@contextmanager
def open_database(db_path: Path) -> Iterator[sqlite3.Connection]:
    """打开 SQLite 连接并确保基础表结构存在。"""

    db_path.parent.mkdir(parents=True, exist_ok=True)
    connection = sqlite3.connect(str(db_path))
    connection.row_factory = sqlite3.Row
    try:
        ensure_database(connection, db_path)
        yield connection
    finally:
        connection.close()


def read_metadata(connection: sqlite3.Connection, key: str) -> Optional[str]:
    """读取 metadata 表中的单个键值，适用于保存采集游标。"""

    row = connection.execute("SELECT value FROM metadata WHERE key = ?", (key,)).fetchone()
    if row is None:
        return None
    return str(row["value"])


def write_metadata(connection: sqlite3.Connection, key: str, value: str) -> None:
    """写入 metadata 表中的单个键值，适用于更新采集游标。"""

    connection.execute(
        """
        INSERT INTO metadata (key, value)
        VALUES (?, ?)
        ON CONFLICT(key) DO UPDATE SET value = excluded.value
        """,
        (key, value),
    )


def isoformat(ts: int, tzinfo: timezone) -> str:
    """将 Unix 时间戳转换为带时区的秒级 ISO 字符串。"""

    return datetime.fromtimestamp(ts, tzinfo).replace(microsecond=0).isoformat()


def now_ts() -> int:
    """返回当前 Unix 秒级时间戳，适用于记录采集和写入时间。"""

    return int(datetime.now().timestamp())


def floor_to_hour(ts: int, tzinfo: timezone) -> int:
    """将时间戳向下取整到本地时区当前小时，适用于小时快照边界。"""

    current = datetime.fromtimestamp(ts, tzinfo)
    floored = current.replace(minute=0, second=0, microsecond=0)
    return int(floored.timestamp())


def date_range_for_day(day: date, tzinfo: timezone) -> Tuple[int, int]:
    """返回指定本地日期的起止 Unix 时间戳，结束时间为开区间。"""

    start_dt = datetime.combine(day, time.min, tzinfo=tzinfo)
    end_dt = start_dt + timedelta(days=1)
    return int(start_dt.timestamp()), int(end_dt.timestamp())


def parse_day(value: str) -> date:
    """解析 YYYY-MM-DD 日期参数，适用于按日期查询或聚合。"""

    try:
        return date.fromisoformat(value)
    except ValueError as exc:
        raise CliError(f"invalid date: {value}") from exc


def resolve_time_range(args: argparse.Namespace, tzinfo: timezone, default_days: int = 7) -> Tuple[int, int]:
    """根据 --date、--from/--to 或 --days 解析查询时间范围。"""

    if getattr(args, "date", None):
        return date_range_for_day(parse_day(args.date), tzinfo)

    if getattr(args, "from_date", None) or getattr(args, "to_date", None):
        if not args.from_date or not args.to_date:
            raise CliError("--from and --to must be used together")
        start_day = parse_day(args.from_date)
        end_day = parse_day(args.to_date)
        start_ts, _ = date_range_for_day(start_day, tzinfo)
        end_ts, _ = date_range_for_day(end_day, tzinfo)
        if end_ts <= start_ts:
            raise CliError("--to must be later than --from")
        return start_ts, end_ts

    days = int(getattr(args, "days", default_days) or default_days)
    if days <= 0:
        raise CliError("--days must be greater than 0")
    end_ts = now_ts()
    start_ts = end_ts - days * 86400
    return start_ts, end_ts


def run_statsquery(config: AppConfig, instance: InstanceConfig, reset: bool) -> str:
    """调用 xray api statsquery 获取统计输出，适用于真实采集和 current 查询。"""

    command = [
        config.xray_bin,
        "api",
        "statsquery",
        f"--server={instance.server}",
    ]
    if reset:
        command.append("-reset=true")

    try:
        result = subprocess.run(
            command,
            check=False,
            capture_output=True,
            text=True,
            timeout=config.timeout_seconds,
        )
    except FileNotFoundError as exc:
        raise CliError(f"xray binary not found: {config.xray_bin}") from exc
    except subprocess.TimeoutExpired as exc:
        raise CliError(f"xray statsquery timed out for instance: {instance.name}") from exc

    if result.returncode != 0:
        stderr = result.stderr.strip() or "unknown error"
        raise CliError(f"xray statsquery failed for instance {instance.name}: {stderr}")
    return result.stdout


def read_stats_source(args: argparse.Namespace, config: AppConfig, instance: InstanceConfig, reset: bool) -> str:
    """读取统计来源；测试或离线导入时可用 --input-file 跳过真实 Xray 调用。"""

    input_file = getattr(args, "input_file", None)
    if input_file:
        try:
            return Path(input_file).read_text(encoding="utf-8")
        except OSError as exc:
            raise CliError(f"failed to read input file: {input_file}: {exc}") from exc
    return run_statsquery(config, instance, reset=reset)


def parse_json_stats(output: str) -> List[ParsedStat]:
    """尝试按 JSON 解析 Xray 输出，适用于当前 StatsService 的结构化输出。"""

    try:
        payload = json.loads(output)
    except json.JSONDecodeError:
        return []

    stats: List[ParsedStat] = []

    def walk(value: Any) -> None:
        if isinstance(value, dict):
            if "name" in value and "value" in value:
                try:
                    stats.append(ParsedStat(str(value["name"]), int(float(value["value"]))))
                except (TypeError, ValueError):
                    logging.warning("Skip stat with invalid value")
            for child in value.values():
                walk(child)
        elif isinstance(value, list):
            for child in value:
                walk(child)

    walk(payload)
    return stats


def parse_text_stats(output: str) -> List[ParsedStat]:
    """按文本行解析 Xray 输出，适用于 JSON 解析失败时的兼容路径。"""

    stats: List[ParsedStat] = []
    current_name: Optional[str] = None
    name_re = re.compile(r'"name"\s*:\s*"([^"]+)"')
    value_re = re.compile(r'"value"\s*:\s*"?([0-9]+(?:\.[0-9]+)?)"?')

    for line in output.splitlines():
        name_match = name_re.search(line)
        if name_match:
            current_name = name_match.group(1)

        value_match = value_re.search(line)
        if value_match and current_name is not None:
            stats.append(ParsedStat(current_name, int(float(value_match.group(1)))))
            current_name = None
    return stats


def parse_stats(output: str) -> List[ParsedStat]:
    """解析 Xray StatsService 输出，优先 JSON，失败后回退到文本解析。"""

    stats = parse_json_stats(output)
    if stats:
        return stats
    return parse_text_stats(output)


def stats_to_counters(stats: Iterable[ParsedStat]) -> Dict[CounterKey, int]:
    """将 Xray 原始统计转换为计数字典，适用于入库和 current 输出。"""

    counters: Dict[CounterKey, int] = {}
    for stat in stats:
        parts = stat.name.split(">>>")
        if len(parts) < 4 or parts[2] != "traffic":
            continue

        scope = parts[0]
        item_name = parts[1]
        direction_token = parts[3]
        if scope not in VALID_SCOPES:
            continue
        if direction_token == "uplink":
            direction = "up"
        elif direction_token == "downlink":
            direction = "down"
        else:
            continue
        if stat.value < 0:
            logging.warning("Skip stat with negative value")
            continue

        key = (scope, item_name, direction)
        counters[key] = counters.get(key, 0) + stat.value
    return counters


def normalize_stats(
    instance: InstanceConfig,
    stats: Iterable[ParsedStat],
    period: str,
    start_ts: int,
    end_ts: int,
    tzinfo: timezone,
) -> List[TrafficRecord]:
    """将 Xray 原始统计名转换为标准结构，适用于统一入库。"""

    counters = stats_to_counters(stats)
    start_time = isoformat(start_ts, tzinfo)
    end_time = isoformat(end_ts, tzinfo)
    records = [
        TrafficRecord(
            instance=instance.name,
            server=instance.server,
            period=period,
            start_ts=start_ts,
            end_ts=end_ts,
            start_time=start_time,
            end_time=end_time,
            scope=scope,
            name=name,
            direction=direction,
            bytes_value=bytes_value,
        )
        for (scope, name, direction), bytes_value in sorted(counters.items())
    ]
    return records


def insert_records(connection: sqlite3.Connection, records: Sequence[TrafficRecord]) -> None:
    """批量写入流量记录，适用于 hourly 和 daily 快照持久化。"""

    created_at = datetime.now(timezone.utc).replace(microsecond=0).isoformat()
    connection.executemany(
        """
        INSERT INTO traffic_records (
            instance, server, period, start_ts, end_ts, start_time, end_time,
            scope, name, direction, bytes, created_at
        )
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        ON CONFLICT(instance, period, start_ts, scope, name, direction) DO UPDATE SET
            server = excluded.server,
            end_ts = excluded.end_ts,
            start_time = excluded.start_time,
            end_time = excluded.end_time,
            bytes = excluded.bytes,
            created_at = excluded.created_at
        """,
        [
            (
                record.instance,
                record.server,
                record.period,
                record.start_ts,
                record.end_ts,
                record.start_time,
                record.end_time,
                record.scope,
                record.name,
                record.direction,
                record.bytes_value,
                created_at,
            )
            for record in records
        ],
    )


def cleanup_old_records(connection: sqlite3.Connection, config: AppConfig) -> int:
    """删除超过保留期的记录，适用于每次采集或手工清理后执行。"""

    cutoff_ts = now_ts() - config.retention_days * 86400
    cursor = connection.execute("DELETE FROM traffic_records WHERE start_ts < ?", (cutoff_ts,))
    return int(cursor.rowcount if cursor.rowcount is not None else 0)


def command_collect_hourly(args: argparse.Namespace, config: AppConfig) -> int:
    """执行小时采集，适用于 systemd timer 每小时调用或手工立即采集。"""

    tzinfo = get_timezone(config)
    selected_instances = select_instances(config, args.instance)
    end_ts = floor_to_hour(now_ts(), tzinfo)
    if getattr(args, "at", None):
        end_dt = datetime.fromisoformat(args.at)
        if end_dt.tzinfo is None:
            end_dt = end_dt.replace(tzinfo=tzinfo)
        end_ts = floor_to_hour(int(end_dt.timestamp()), tzinfo)

    errors: List[str] = []
    total_records = 0
    for instance in selected_instances:
        try:
            with database_lock(config.db_path):
                with open_database(config.db_path) as connection:
                    metadata_key = f"last_hourly_end_ts:{instance.name}"
                    last_end = read_metadata(connection, metadata_key)
                    if last_end and int(last_end) >= end_ts:
                        logging.info(
                            "Hourly snapshot skipped: instance=%s last_end=%s end_ts=%s",
                            instance.name,
                            last_end,
                            end_ts,
                        )
                        continue

                    raw_output = read_stats_source(
                        args,
                        config,
                        instance,
                        reset=not getattr(args, "no_reset", False),
                    )
                    parsed_stats = parse_stats(raw_output)
                    if raw_output.strip() and not parsed_stats:
                        raise CliError(f"no valid stats parsed for instance: {instance.name}")
                    start_ts = int(last_end) if last_end else end_ts - 3600

                    records = normalize_stats(instance, parsed_stats, "hourly", start_ts, end_ts, tzinfo)
                    insert_records(connection, records)
                    write_metadata(connection, metadata_key, str(end_ts))
                    removed = cleanup_old_records(connection, config)
                    connection.commit()
            total_records += len(records)
            logging.info(
                "Hourly snapshot saved: instance=%s records=%s removed=%s",
                instance.name,
                len(records),
                removed,
            )
        except CliError as exc:
            errors.append(str(exc))
            logging.error("%s", exc)

    if errors:
        return 1
    logging.info("Hourly collection finished: instances=%s records=%s", len(selected_instances), total_records)
    return 0


def command_collect_daily(args: argparse.Namespace, config: AppConfig) -> int:
    """执行每日聚合，适用于每天凌晨从 hourly 记录生成 daily 记录。"""

    tzinfo = get_timezone(config)
    selected_instances = select_instances(config, args.instance)
    target_day = parse_day(args.date) if args.date else datetime.now(tzinfo).date() - timedelta(days=1)
    start_ts, end_ts = date_range_for_day(target_day, tzinfo)
    start_time = isoformat(start_ts, tzinfo)
    end_time = isoformat(end_ts, tzinfo)
    total_records = 0

    with database_lock(config.db_path):
        with open_database(config.db_path) as connection:
            for instance in selected_instances:
                rows = connection.execute(
                    """
                    SELECT scope, name, direction, SUM(bytes) AS bytes
                    FROM traffic_records
                    WHERE instance = ?
                      AND period = 'hourly'
                      AND start_ts >= ?
                      AND start_ts < ?
                    GROUP BY scope, name, direction
                    ORDER BY scope, name, direction
                    """,
                    (instance.name, start_ts, end_ts),
                ).fetchall()

                connection.execute(
                    "DELETE FROM traffic_records WHERE instance = ? AND period = 'daily' AND start_ts = ?",
                    (instance.name, start_ts),
                )
                records = [
                    TrafficRecord(
                        instance=instance.name,
                        server=instance.server,
                        period="daily",
                        start_ts=start_ts,
                        end_ts=end_ts,
                        start_time=start_time,
                        end_time=end_time,
                        scope=str(row["scope"]),
                        name=str(row["name"]),
                        direction=str(row["direction"]),
                        bytes_value=int(row["bytes"] or 0),
                    )
                    for row in rows
                ]
                insert_records(connection, records)
                total_records += len(records)
                logging.info(
                    "Daily snapshot saved: instance=%s date=%s records=%s",
                    instance.name,
                    target_day.isoformat(),
                    len(records),
                )
            removed = cleanup_old_records(connection, config)
            connection.commit()

    logging.info("Daily collection finished: instances=%s records=%s removed=%s", len(selected_instances), total_records, removed)
    return 0


def calculate_current_totals(
    instance: InstanceConfig,
    counters: Dict[CounterKey, int],
    scope_filter: Optional[str],
    name_filter: Optional[str],
) -> List[Tuple[str, str, str, int, int, int]]:
    """将当前累计计数按 instance/scope/name 汇总，适用于 current 输出。"""

    grouped: Dict[Tuple[str, str, str], Dict[str, int]] = {}
    for scope, name, direction in sorted(counters):
        if scope_filter and scope != scope_filter:
            continue
        if name_filter and name != name_filter:
            continue

        item = grouped.setdefault((instance.name, scope, name), {"up": 0, "down": 0})
        item[direction] = item.get(direction, 0) + counters[(scope, name, direction)]

    rows = []
    for (instance_name, scope, name), values in grouped.items():
        up_bytes = values.get("up", 0)
        down_bytes = values.get("down", 0)
        total_bytes = up_bytes + down_bytes
        if total_bytes <= 0:
            continue
        rows.append((instance_name, scope, name, up_bytes, down_bytes, total_bytes))
    rows.sort(key=lambda row: (row[0], -row[5], row[1], row[2]))
    return rows


def write_current_table(rows: Sequence[Tuple[str, str, str, int, int, int]], output: TextIO) -> None:
    """输出当前累计流量表格，适用于 show current 的人类可读结果。"""

    output.write(f"{'Instance':<12} {'Scope':<10} {'Name':<30} {'Up':>12} {'Down':>12} {'Total':>12}\n")
    output.write(f"{'-' * 12} {'-' * 10} {'-' * 30} {'-' * 12} {'-' * 12} {'-' * 12}\n")
    for instance, scope, name, up_bytes, down_bytes, total_bytes in rows:
        output.write(
            f"{instance:<12} {scope:<10} {name:<30} "
            f"{format_bytes(up_bytes):>12} {format_bytes(down_bytes):>12} {format_bytes(total_bytes):>12}\n"
        )


def read_current_rows(
    config: AppConfig,
    instances: Sequence[InstanceConfig],
    scope_filter: Optional[str],
    name_filter: Optional[str],
    log_errors: bool = True,
) -> Tuple[List[Tuple[str, str, str, int, int, int]], List[str]]:
    """查询当前累计流量并返回表格行，适用于 show/watch current 复用。"""

    rows: List[Tuple[str, str, str, int, int, int]] = []
    errors: List[str] = []
    for instance in instances:
        try:
            counters = stats_to_counters(parse_stats(run_statsquery(config, instance, reset=False)))
            rows.extend(calculate_current_totals(instance, counters, scope_filter, name_filter))
        except CliError as exc:
            errors.append(str(exc))
            if log_errors:
                logging.error("%s", exc)
    return rows, errors


def write_current_rows(rows: Sequence[Tuple[str, str, str, int, int, int]], output: TextIO) -> None:
    """输出当前累计流量或空提示，适用于 show/watch current 共用。"""

    if rows:
        write_current_table(rows, output)
    else:
        output.write("No current traffic counters found\n")


def clear_terminal(output: TextIO) -> None:
    """清空终端视图，适用于 watch current 默认刷新显示。"""

    output.write("\033[2J\033[H")


def write_watch_current_view(
    rows: Sequence[Tuple[str, str, str, int, int, int]],
    errors: Sequence[str],
    tzinfo: timezone,
    output: TextIO,
) -> None:
    """输出 watch current 单轮视图，适用于持续查看当前累计流量。"""

    output.write(f"Current time: {format_datetime_label(now_ts(), tzinfo)}\n")
    for error in errors:
        output.write(f"ERROR {error}\n")
    write_current_rows(rows, output)


def command_show_current(args: argparse.Namespace, config: AppConfig) -> int:
    """查询上次 reset 后的当前累计流量，适用于不落库的即时累计查看。"""

    selected_instances = select_instances(config, args.instance)
    rows, errors = read_current_rows(config, selected_instances, args.scope, args.name)
    write_current_rows(rows, sys.stdout)
    return 1 if errors else 0


def command_watch_current(args: argparse.Namespace, config: AppConfig) -> int:
    """持续查询当前累计流量，适用于观察指定实例的即时累计变化。"""

    if not math.isfinite(args.interval) or args.interval <= 0:
        raise CliError("--interval must be greater than 0")
    if args.count < 0:
        raise CliError("--count must be greater than or equal to 0")

    tzinfo = get_timezone(config)
    selected_instances = select_instances(config, args.instance)
    iteration = 0
    had_errors = False
    try:
        while args.count == 0 or iteration < args.count:
            if args.no_clear and iteration > 0:
                sys.stdout.write("\n")
            elif not args.no_clear:
                clear_terminal(sys.stdout)

            rows, errors = read_current_rows(config, selected_instances, args.scope, args.name, log_errors=False)
            had_errors = had_errors or bool(errors)
            write_watch_current_view(rows, errors, tzinfo, sys.stdout)
            sys.stdout.flush()

            iteration += 1
            if args.count != 0 and iteration >= args.count:
                break
            time_module.sleep(args.interval)
    except KeyboardInterrupt:
        sys.stdout.write("\n")
        return 0
    return 1 if had_errors else 0


def format_bytes(value: int) -> str:
    """将字节数格式化为 IEC 单位，适用于终端表格展示。"""

    units = ["B", "KiB", "MiB", "GiB", "TiB", "PiB"]
    size = float(value)
    for unit in units:
        if abs(size) < 1024.0 or unit == units[-1]:
            if unit == "B":
                return f"{int(size)}B"
            return f"{size:.2f}{unit}"
        size /= 1024.0
    return f"{value}B"


def format_datetime_label(ts: int, tzinfo: timezone) -> str:
    """格式化带时区的时间标签，适用于 summarize 元信息展示。"""

    label_dt = datetime.fromtimestamp(ts, tzinfo).replace(microsecond=0)
    offset = label_dt.strftime("%z")
    if offset:
        offset = f"{offset[:3]}:{offset[3:]}"
        return f"{label_dt.strftime('%Y-%m-%d %H:%M:%S')} {offset}"
    return label_dt.strftime("%Y-%m-%d %H:%M:%S")


def write_summary_context(
    period: str,
    instance_name: str,
    start_ts: int,
    end_ts: int,
    tzinfo: timezone,
    scope: Optional[str],
    name: Optional[str],
    output: TextIO,
) -> None:
    """输出 summarize 查询上下文，避免汇总结果缺少时间范围说明。"""

    output.write(f"Period:   {period}\n")
    output.write(f"Range:    {format_datetime_label(start_ts, tzinfo)} -> {format_datetime_label(end_ts, tzinfo)}\n")
    output.write(f"Instance: {instance_name}\n")
    output.write(f"Scope:    {scope or 'all'}\n")
    output.write(f"Name:     {name or 'all'}\n\n")


def write_summary_table(rows: Sequence[sqlite3.Row], output: TextIO) -> None:
    """输出汇总表格，适用于 summarize 子命令的人类可读结果。"""

    output.write(f"{'Instance':<12} {'Scope':<10} {'Name':<30} {'Up':>12} {'Down':>12} {'Total':>12}\n")
    output.write(f"{'-' * 12} {'-' * 10} {'-' * 30} {'-' * 12} {'-' * 12} {'-' * 12}\n")
    for row in rows:
        up_bytes = int(row["up_bytes"] or 0)
        down_bytes = int(row["down_bytes"] or 0)
        total_bytes = int(row["total_bytes"] or 0)
        output.write(
            f"{row['instance']:<12} {row['scope']:<10} {row['name']:<30} "
            f"{format_bytes(up_bytes):>12} {format_bytes(down_bytes):>12} {format_bytes(total_bytes):>12}\n"
        )


def format_period_label(period: str, start_ts: int, tzinfo: timezone) -> str:
    """格式化快照时间标签，适用于 show 子命令按小时或天展示。"""

    start_dt = datetime.fromtimestamp(start_ts, tzinfo)
    if period == "hourly":
        return start_dt.strftime("%Y-%m-%d %H:00")
    return start_dt.strftime("%Y-%m-%d")


def resolve_show_time_range(args: argparse.Namespace, tzinfo: timezone) -> Tuple[int, int]:
    """解析 show 子命令的时间范围，默认 hourly 查 1 天、daily 查 7 天。"""

    if args.date:
        return date_range_for_day(parse_day(args.date), tzinfo)

    days = args.days
    if days is None:
        days = 1 if args.period == "hourly" else 7
    if days <= 0:
        raise CliError("--days must be greater than 0")

    end_ts = now_ts()
    start_ts = end_ts - days * 86400
    return start_ts, end_ts


def instance_filter_sql(instances: Sequence[InstanceConfig]) -> Tuple[str, List[str]]:
    """生成 instance IN 过滤 SQL，适用于所有读查询。"""

    placeholders = ", ".join("?" for _ in instances)
    return f"instance IN ({placeholders})", [instance.name for instance in instances]


def write_show_table(period: str, rows: Sequence[sqlite3.Row], tzinfo: timezone, output: TextIO) -> None:
    """输出按小时或天聚合后的流量表格，适用于日常查看已存储流量。"""

    label = "Hour" if period == "hourly" else "Day"
    separator = f"{'-' * 16} {'-' * 12} {'-' * 10} {'-' * 30} {'-' * 12} {'-' * 12} {'-' * 12}"
    output.write(f"{label:<16} {'Instance':<12} {'Scope':<10} {'Name':<30} {'Up':>12} {'Down':>12} {'Total':>12}\n")
    output.write(f"{separator}\n")
    last_period_label = ""
    for row in rows:
        up_bytes = int(row["up_bytes"] or 0)
        down_bytes = int(row["down_bytes"] or 0)
        total_bytes = int(row["total_bytes"] or 0)
        current_period_label = format_period_label(period, int(row["start_ts"]), tzinfo)
        if last_period_label and current_period_label != last_period_label:
            output.write(f"{separator}\n")
        output.write(
            f"{current_period_label:<16} {row['instance']:<12} "
            f"{row['scope']:<10} {row['name']:<30} "
            f"{format_bytes(up_bytes):>12} {format_bytes(down_bytes):>12} {format_bytes(total_bytes):>12}\n"
        )
        last_period_label = current_period_label


def command_show_records(args: argparse.Namespace, config: AppConfig) -> int:
    """按小时或天查看已存储流量，适用于日常阅读场景。"""

    tzinfo = get_timezone(config)
    selected_instances = select_instances(config, args.instance)
    if args.limit <= 0:
        raise CliError("--limit must be greater than 0")
    start_ts, end_ts = resolve_show_time_range(args, tzinfo)
    instance_filter, instance_params = instance_filter_sql(selected_instances)
    filters = [instance_filter, "period = ?", "start_ts >= ?", "start_ts < ?"]
    params: List[Any] = [*instance_params, args.period, start_ts, end_ts]

    if args.scope:
        filters.append("scope = ?")
        params.append(args.scope)
    if args.name:
        filters.append("name = ?")
        params.append(args.name)

    params.append(args.limit)
    query = f"""
        SELECT
            start_ts,
            instance,
            scope,
            name,
            SUM(CASE WHEN direction = 'up' THEN bytes ELSE 0 END) AS up_bytes,
            SUM(CASE WHEN direction = 'down' THEN bytes ELSE 0 END) AS down_bytes,
            SUM(bytes) AS total_bytes
        FROM traffic_records
        WHERE {' AND '.join(filters)}
        GROUP BY start_ts, instance, scope, name
        ORDER BY start_ts DESC, instance ASC, total_bytes DESC, scope ASC, name ASC
        LIMIT ?
    """

    with open_database(config.db_path) as connection:
        rows = connection.execute(query, params).fetchall()

    if not rows:
        sys.stdout.write("No records found\n")
        return 0
    write_show_table(args.period, rows, tzinfo, sys.stdout)
    return 0


def command_summarize_records(args: argparse.Namespace, config: AppConfig) -> int:
    """按条件输出流量汇总，适用于按实例、用户、入口或出口做统计。"""

    tzinfo = get_timezone(config)
    selected_instances = select_instances(config, args.instance)
    start_ts, end_ts = resolve_time_range(args, tzinfo)
    instance_filter, instance_params = instance_filter_sql(selected_instances)
    filters = [instance_filter, "period = ?", "start_ts >= ?", "start_ts < ?"]
    params: List[Any] = [*instance_params, args.period, start_ts, end_ts]

    if args.scope:
        filters.append("scope = ?")
        params.append(args.scope)
    if args.name:
        filters.append("name = ?")
        params.append(args.name)

    query = f"""
        SELECT
            instance,
            scope,
            name,
            SUM(CASE WHEN direction = 'up' THEN bytes ELSE 0 END) AS up_bytes,
            SUM(CASE WHEN direction = 'down' THEN bytes ELSE 0 END) AS down_bytes,
            SUM(bytes) AS total_bytes
        FROM traffic_records
        WHERE {' AND '.join(filters)}
        GROUP BY instance, scope, name
        ORDER BY instance ASC, total_bytes DESC, scope ASC, name ASC
    """

    with open_database(config.db_path) as connection:
        rows = connection.execute(query, params).fetchall()

    write_summary_context(args.period, args.instance, start_ts, end_ts, tzinfo, args.scope, args.name, sys.stdout)
    if not rows:
        sys.stdout.write("No records found\n")
        return 0
    write_summary_table(rows, sys.stdout)
    return 0


def command_export_records(args: argparse.Namespace, config: AppConfig) -> int:
    """导出 CSV 明细，适用于报表系统或人工二次分析。"""

    tzinfo = get_timezone(config)
    selected_instances = select_instances(config, args.instance)
    start_ts, end_ts = resolve_time_range(args, tzinfo)
    instance_filter, instance_params = instance_filter_sql(selected_instances)
    filters = [instance_filter, "period = ?", "start_ts >= ?", "start_ts < ?"]
    params: List[Any] = [*instance_params, args.period, start_ts, end_ts]

    if args.scope:
        filters.append("scope = ?")
        params.append(args.scope)
    if args.name:
        filters.append("name = ?")
        params.append(args.name)

    query = f"""
        SELECT instance, server, period, start_time, end_time, scope, name, direction, bytes, created_at
        FROM traffic_records
        WHERE {' AND '.join(filters)}
        ORDER BY start_ts ASC, instance ASC, scope ASC, name ASC, direction ASC
    """

    with open_database(config.db_path) as connection:
        rows = connection.execute(query, params).fetchall()

    output_file: Optional[TextIO] = None
    try:
        output: TextIO
        if args.output:
            try:
                output_file = Path(args.output).open("w", encoding="utf-8", newline="")
            except OSError as exc:
                raise CliError(f"failed to open output file: {args.output}: {exc}") from exc
            output = output_file
        else:
            output = sys.stdout

        writer = csv.writer(output)
        writer.writerow(
            ["instance", "server", "period", "start_time", "end_time", "scope", "name", "direction", "bytes", "created_at"]
        )
        for row in rows:
            writer.writerow(
                [
                    row["instance"],
                    row["server"],
                    row["period"],
                    row["start_time"],
                    row["end_time"],
                    row["scope"],
                    row["name"],
                    row["direction"],
                    row["bytes"],
                    row["created_at"],
                ]
            )
    finally:
        if output_file is not None:
            output_file.close()

    logging.info("CSV exported: records=%s", len(rows))
    return 0


def command_cleanup_records(args: argparse.Namespace, config: AppConfig) -> int:
    """手工清理过期数据，适用于需要立即执行保留期策略的场景。"""

    del args
    with database_lock(config.db_path):
        with open_database(config.db_path) as connection:
            removed = cleanup_old_records(connection, config)
            connection.commit()
    logging.info("Cleanup finished: removed=%s", removed)
    return 0


