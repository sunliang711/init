def should_page_help(help_text: str, output: TextIO) -> bool:
    """判断帮助信息是否需要分页，适用于交互式终端输出。"""

    if output is not sys.stdout:
        return False
    if not output.isatty():
        return False
    if shutil.which("less") is None:
        return False
    terminal_lines = shutil.get_terminal_size(fallback=(80, 24)).lines
    return len(help_text.splitlines()) > terminal_lines


def page_help_text(help_text: str) -> bool:
    """使用 less 分页输出帮助信息，适用于内容超过当前终端高度的场景。"""

    less_bin = shutil.which("less")
    if less_bin is None:
        return False
    try:
        result = subprocess.run([less_bin, "-R"], input=help_text, text=True, check=False)
    except OSError:
        return False
    return result.returncode == 0


class PagingArgumentParser(argparse.ArgumentParser):
    """支持交互式分页输出帮助信息的命令行解析器。"""

    def print_help(self, file: Optional[TextIO] = None) -> None:
        """打印帮助信息，交互式终端内容超屏时自动使用 less 分页。"""

        if file is None:
            file = sys.stdout
        help_text = self.format_help()
        if should_page_help(help_text, file) and page_help_text(help_text):
            return
        file.write(help_text)

