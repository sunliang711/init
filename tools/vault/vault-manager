Examples:
  ${VAULT_MANAGER_CMD} install
  ${VAULT_MANAGER_CMD} install --version 2.0.0
  ${VAULT_MANAGER_CMD} install --api-addr http://10.2.37.64:8200 --cluster-addr http://10.2.37.64:8201
