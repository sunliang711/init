tutor_usage() {
  local topic="${1:-overview}"

  case "$topic" in
    overview | help | -h | --help)
      cat <<EOF
Vault manager tutor

Usage:
  ${VAULT_MANAGER_CMD} tutor [topic]

Mental model:
  vault-manager works at the Vault service and administration layer.
  install creates the service and config.
  init creates unseal keys and a root token once.
  unseal makes Vault usable after initialization or restart.
  auth and policy configure how clients authenticate and what they can read.
  Use nomad-manager vault-jwt when Nomad jobs should read Vault secrets.

Workflows:
  secret         Enable KV v2, write a secret and prepare Nomad access.
  nomad-jwt      Prepare Vault JWT Auth for Nomad workload identity.

References:
  install        Install and verify a single-node Vault service.
  init           Initialize, unseal and reuse the init JSON safely.
  auth           Enable, configure, list and disable auth methods.
  policy         Write, read and delete policies from local HCL files.
  recovery       Recover common init, seal and token-file situations.
  uninstall      Choose a conservative or destructive removal level.

Troubleshooting:
  troubleshoot   Check service, health, seal, auth, policy and audit signals.

Command help:
  ${VAULT_MANAGER_CMD} auth --help
  ${VAULT_MANAGER_CMD} policy --help

Example:
  ${VAULT_MANAGER_CMD} tutor install
  ${VAULT_MANAGER_CMD} tutor secret
EOF
      ;;
    install)
      cat <<EOF
Scenario: install Vault single node
Use when: You need a local Vault service managed by this tool.
Outcome: A running single-node Vault service with management metadata.

Before you start:
  Run on Linux with root privilege or sudo.
  Confirm outbound access to HashiCorp releases, or configure http_proxy/https_proxy.
  Decide whether the API address should be localhost or reachable by other nodes.

1. Install latest Vault:
   ${VAULT_MANAGER_CMD} install

2. Install through an HTTP proxy:
   http_proxy=http://10.2.1.107:7190 https_proxy=http://10.2.1.107:7190 ${VAULT_MANAGER_CMD} install

3. Install with an address reachable by other nodes:
   ${VAULT_MANAGER_CMD} install --api-addr http://10.2.37.64:8200 --cluster-addr http://10.2.37.64:8201

4. Install with listener TLS and an auto-generated certificate:
   ${VAULT_MANAGER_CMD} install --tls-auto --tls-ip 10.2.37.64 --api-addr https://10.2.37.64:8200 --cluster-addr https://10.2.37.64:8201

5. Check service and metadata:
   systemctl status vault
   ${VAULT_MANAGER_CMD} status
   cat ${INSTALL_METADATA_FILE}

Verify:
  systemctl status vault shows active.
  ${VAULT_MANAGER_CMD} status reaches the Vault API.
  ${INSTALL_METADATA_FILE} exists and records the installed tool snapshot.

Common failures:
  Release download blocked by network or proxy settings.
  Missing root privilege prevents service and file installation.
  api_addr points to localhost when other nodes need to reach Vault.
  TLS certificates miss the IP or DNS name used in api_addr.

Notes:
  install configures single-node raft storage under ${DATA_DIR}.
  TLS installs client defaults under ${CLIENT_ENV_FILE}.
  Future management can use ${TOOL_ENTRY}, which points to the installed script snapshot.
EOF
      ;;
    init)
      cat <<EOF
Scenario: initialize and unseal Vault
Use when: Vault is installed but not initialized or is sealed after restart.
Outcome: An initialized and unsealed Vault instance with a reusable token file.

Before you start:
  Run init only once for a Vault data directory.
  Choose where to store the init JSON and restrict its permissions.
  Do not delete ${STATE_DIR} or ${INIT_DIR} unless you intend to rebuild state.

1. Initialize Vault and save the init JSON:
   ${VAULT_MANAGER_CMD} init --key-shares 1 --key-threshold 1 --out ${INIT_DIR}/vault-init.json

2. Unseal Vault from the init JSON:
   ${VAULT_MANAGER_CMD} unseal --keys-file ${INIT_DIR}/vault-init.json

3. Use the init JSON as a token file:
   ${VAULT_MANAGER_CMD} status --token-file ${INIT_DIR}/vault-init.json

4. Check health:
   ${VAULT_MANAGER_CMD} doctor --addr ${DEFAULT_VAULT_ADDR}

Verify:
  ${VAULT_MANAGER_CMD} status shows initialized=true and sealed=false.
  ${VAULT_MANAGER_CMD} auth list --token-file ${INIT_DIR}/vault-init.json succeeds.

Common failures:
  Running init again after Vault is already initialized.
  Losing the init JSON before storing unseal keys and root token safely.
  Vault remains sealed after restart until unseal is run again.

Safety:
  The init JSON contains unseal keys and the root token.
  Keep it readable only by trusted administrators.
  Do not run init again when Vault is already initialized.
EOF
      ;;
    secret | kv-secret)
      cat <<EOF
Scenario: store and read application secrets with KV v2
Use when: Applications need secrets stored in Vault KV v2.
Outcome: A Vault secret at kv/app and a Nomad job example for kv/data/app.

Before you start:
  Vault must be initialized, unsealed and authenticated.
  Know the difference between KV CLI paths and KV v2 API/template paths.
  Use placeholder values when learning the workflow.

1. Make sure Vault is initialized and unsealed:
   ${VAULT_MANAGER_CMD} status
   ${VAULT_MANAGER_CMD} unseal --keys-file ${INIT_DIR}/vault-init.json

2. Export Vault address and a setup token:
   export VAULT_ADDR=${DEFAULT_VAULT_ADDR}
   export VAULT_TOKEN=<root-token-from-${INIT_DIR}/vault-init.json>

3. Enable KV v2 once at path kv:
   vault secrets enable -path=kv kv-v2

4. Write and read an application secret:
   vault kv put kv/app value='my-secret-value'
   vault kv get kv/app
   vault kv get -field=value kv/app

5. Allow a Nomad job to read that secret:
   nomad-manager vault-jwt apply --profile default --vault-addr ${DEFAULT_VAULT_ADDR} --nomad-addr http://127.0.0.1:4646 --secret-path kv/data/app
   nomad-manager vault-jwt job-example --profile default --job app --secret kv/data/app --out jobs/app-vault.nomad.hcl

Verify:
  vault kv get kv/app returns the secret.
  nomad-manager vault-jwt doctor --profile default succeeds after the Nomad link is applied.

Common failures:
  Vault is sealed or VAULT_TOKEN is missing.
  kv/ is already enabled and the enable command fails.
  Nomad policy uses kv/data/app but the secret was written to a different path.

Notes:
  vault kv put uses the KV CLI path kv/app.
  Nomad templates and Vault policies use the KV v2 API path kv/data/app.
  If kv/ is already enabled, skip the vault secrets enable command.
  Avoid putting real secret values directly in shared shell history.
EOF
      ;;
    auth)
      cat <<EOF
Scenario: manage Vault auth methods
Use when: You need repeatable commands for Vault auth method lifecycle.
Outcome: Auth methods managed through vault-manager commands.

Before you start:
  Use a token with permission to manage auth methods.
  Choose stable mount paths, because clients and policies may depend on them.

1. List enabled auth methods:
   ${VAULT_MANAGER_CMD} auth list --token-file ${INIT_DIR}/vault-init.json

2. Enable userpass auth:
   ${VAULT_MANAGER_CMD} auth enable userpass --token-file ${INIT_DIR}/vault-init.json

3. Enable JWT auth at a custom path:
   ${VAULT_MANAGER_CMD} auth enable jwt --path jwt-nomad --description "Nomad workload identity" --token-file ${INIT_DIR}/vault-init.json

4. Write an auth config:
   ${VAULT_MANAGER_CMD} auth write jwt-nomad/config jwks_url=http://127.0.0.1:4646/.well-known/jwks.json default_role=nomad-workloads --token-file ${INIT_DIR}/vault-init.json

5. Disable an auth method:
   ${VAULT_MANAGER_CMD} auth disable userpass --token-file ${INIT_DIR}/vault-init.json

Verify:
  ${VAULT_MANAGER_CMD} auth list --token-file ${INIT_DIR}/vault-init.json
  ${VAULT_MANAGER_CMD} auth read jwt-nomad/config --token-file ${INIT_DIR}/vault-init.json

Common failures:
  Enabling a path that already exists with a different auth type.
  Writing auth config keys that are invalid for that auth method.
  Passing secret values as <KEY=VALUE> command arguments.

Notes:
  auth write <KEY=VALUE> values may appear in shell history and audit logs.
  Avoid passing secret values directly on the command line.
EOF
      ;;
    policy)
      cat <<EOF
Scenario: manage Vault policies
Use when: You need file-based policy changes that can be reviewed and repeated.
Outcome: A policy workflow you can adapt for application access rules.

Before you start:
  Use a token with permission to read and write policies.
  Decide the exact paths and capabilities before applying the policy.

1. Create a policy file:
   cat > app-read.hcl <<'HCL'
   path "kv/data/app/*" {
     capabilities = ["read"]
   }

   path "kv/metadata/app/*" {
     capabilities = ["read", "list"]
   }
HCL

2. Write the policy:
   ${VAULT_MANAGER_CMD} policy write app-read ./app-read.hcl --token-file ${INIT_DIR}/vault-init.json

3. Read the policy:
   ${VAULT_MANAGER_CMD} policy read app-read --token-file ${INIT_DIR}/vault-init.json

4. Delete the policy:
   ${VAULT_MANAGER_CMD} policy delete app-read --token-file ${INIT_DIR}/vault-init.json

Verify:
  ${VAULT_MANAGER_CMD} policy read app-read --token-file ${INIT_DIR}/vault-init.json
  vault token capabilities <token> kv/data/app

Common failures:
  KV v2 data and metadata paths are confused.
  Policy paths are too broad or do not match the application path.
  The policy file path is wrong or unreadable.

Notes:
  Keep policies narrow. Prefer explicit paths over broad wildcards.
  Review KV v2 data and metadata paths separately.
EOF
      ;;
    nomad-jwt)
      cat <<EOF
Scenario: prepare Vault for Nomad workload identity
Use when: Nomad jobs should authenticate to Vault without static Vault tokens.
Outcome: Vault auth, policy and role linked through nomad-manager vault-jwt apply.

Recommended path:
  Use nomad-manager vault-jwt apply because it configures both Nomad and Vault in one linked workflow.

Before you start:
  Vault must be initialized and unsealed.
  Nomad must be running and expose a JWKS URL reachable from Vault.
  VAULT_TOKEN must allow auth method, policy and role changes.

1. Initialize and unseal Vault first:
   ${VAULT_MANAGER_CMD} tutor init

2. Export a Vault token or use --token-file:
   export VAULT_TOKEN=<redacted>

3. Run the linked Nomad workflow:
   nomad-manager vault-jwt plan --profile default --vault-addr ${DEFAULT_VAULT_ADDR} --nomad-addr http://10.2.37.64:4646
   nomad-manager vault-jwt apply --profile default --vault-addr ${DEFAULT_VAULT_ADDR} --nomad-addr http://10.2.37.64:4646 --secret-path kv/data/app

4. Check Vault pieces manually when needed:
   ${VAULT_MANAGER_CMD} auth read jwt-nomad/config --token-file ${INIT_DIR}/vault-init.json
   ${VAULT_MANAGER_CMD} policy read nomad-workloads --token-file ${INIT_DIR}/vault-init.json
   VAULT_ADDR=${DEFAULT_VAULT_ADDR} vault read auth/jwt-nomad/role/nomad-workloads

Verify:
  nomad-manager vault-jwt doctor --profile default
  VAULT_ADDR=${DEFAULT_VAULT_ADDR} vault read auth/jwt-nomad/role/nomad-workloads

Common failures:
  Vault cannot reach Nomad's JWKS endpoint.
  The role audience does not match the Nomad job identity audience.
  The policy does not allow the KV v2 data path used by the job.

Notes:
  The Nomad address must be reachable from Vault for JWKS discovery.
  Pass concrete --secret-path values for production policies.
EOF
      ;;
    recovery)
      cat <<EOF
Scenario: recover common Vault operational situations
Use when: Vault is sealed, token access is unclear or local state was removed.
Outcome: A decision checklist that avoids re-initializing an existing Vault.

Before you start:
  Do not delete state or run init while investigating.
  First determine whether Vault is uninitialized, sealed, unreachable or simply unauthenticated.

1. Check whether Vault is initialized, sealed or unavailable:
   ${VAULT_MANAGER_CMD} status
   ${VAULT_MANAGER_CMD} doctor --addr ${DEFAULT_VAULT_ADDR}

2. If Vault is sealed, unseal it from the saved init JSON:
   ${VAULT_MANAGER_CMD} unseal --keys-file ${INIT_DIR}/vault-init.json

3. If a manager command needs authentication, use the init JSON token file:
   ${VAULT_MANAGER_CMD} auth list --token-file ${INIT_DIR}/vault-init.json
   ${VAULT_MANAGER_CMD} policy list --token-file ${INIT_DIR}/vault-init.json

4. If the root token was lost but another admin token exists:
   export VAULT_TOKEN=<admin-token>
   VAULT_ADDR=${DEFAULT_VAULT_ADDR} vault token lookup
   VAULT_ADDR=${DEFAULT_VAULT_ADDR} vault token create -policy=<admin-policy>

5. If local raft data or init output was removed:
   Restore ${STATE_DIR} and ${INIT_DIR} from backup before starting Vault.

Verify:
  ${VAULT_MANAGER_CMD} status shows the expected initialized and sealed state.
  ${VAULT_MANAGER_CMD} auth list --token-file ${INIT_DIR}/vault-init.json succeeds after recovery.

Common failures:
  Treating sealed Vault as uninitialized.
  Expecting unseal keys to recover a lost root token.
  Starting Vault with missing raft data after deleting ${STATE_DIR}.

Notes:
  Do not run init again when Vault status says initialized=true.
  Unseal keys cannot recover a lost root token by themselves; you need another valid token or recovery procedure.
EOF
      ;;
    uninstall)
      cat <<EOF
Scenario: uninstall Vault safely
Use when: You need to remove Vault runtime, state, tools or audit metadata.
Outcome: A removal command that matches the intended cleanup scope.

Before you start:
  Decide whether raft data, init output, metadata and audit logs must be retained.
  Back up ${STATE_DIR} and ${INIT_DIR} if the instance may need recovery.

1. Remove service, binary and config. Keep Vault state, tools, metadata and audit logs:
   ${VAULT_MANAGER_CMD} uninstall

2. Also remove Vault state under ${STATE_DIR} and init output under ${INIT_DIR}:
   ${VAULT_MANAGER_CMD} uninstall --purge-data

3. Remove runtime and installed management scripts. Keep metadata and audit logs:
   ${VAULT_MANAGER_CMD} uninstall --remove-tools

4. Remove runtime, Vault state, tools, metadata and audit logs:
   ${VAULT_MANAGER_CMD} uninstall --purge

Verify:
  systemctl status vault should no longer show a running service after uninstall.
  Check ${STATE_DIR} and ${INIT_DIR} only after choosing the intended removal level.

Common failures:
  Using --purge-data or --purge before backing up raft data and init output.
  Expecting default uninstall to delete Vault state.

Notes:
  Default uninstall keeps ${STATE_DIR} and ${INIT_DIR} because they can contain raft data and init output.
EOF
      ;;
    troubleshoot)
      cat <<EOF
Scenario: Vault troubleshooting
Use when: Vault health, seal state, auth, policy or service status looks wrong.
Outcome: A general diagnostics checklist for Vault itself.

Before you start:
  Identify whether the failure is service startup, network reachability, seal state, authentication or authorization.

1. Check service logs:
   systemctl status vault
   journalctl -u vault -n 100 --no-pager

2. Check Vault status and health:
   ${VAULT_MANAGER_CMD} status
   ${VAULT_MANAGER_CMD} doctor --addr ${DEFAULT_VAULT_ADDR}
   curl --noproxy '*' ${DEFAULT_VAULT_ADDR}/v1/sys/health

3. Check seal state and unseal when needed:
   ${VAULT_MANAGER_CMD} status
   ${VAULT_MANAGER_CMD} unseal --keys-file ${INIT_DIR}/vault-init.json

4. Check auth and policy state:
   ${VAULT_MANAGER_CMD} auth list --token-file ${INIT_DIR}/vault-init.json
   ${VAULT_MANAGER_CMD} policy list --token-file ${INIT_DIR}/vault-init.json

5. Check management metadata and audit history:
   cat ${INSTALL_METADATA_FILE}
   tail -n 50 ${AUDIT_LOG_FILE}

Verify:
  ${VAULT_MANAGER_CMD} status returns a clear initialized/sealed state.
  ${VAULT_MANAGER_CMD} doctor --addr ${DEFAULT_VAULT_ADDR} reaches the health endpoint.

Common failures:
  Vault service is running but sealed.
  VAULT_ADDR points to the wrong listener.
  Token file is missing, unreadable or does not contain a valid token.
  Policy allows the wrong KV v2 path.
EOF
      ;;
    *)
      return 1
      ;;
  esac
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

require_command() {
  if ! command_exists "$1"; then
    fatal "Required command not found: $1"
  fi
}

require_any_checksum_command() {
  if ! command_exists sha256sum && ! command_exists shasum; then
    fatal "Required command not found: sha256sum or shasum"
  fi
}

require_zip_extractor() {
  if ! command_exists unzip && ! command_exists python3; then
    fatal "Required command not found: unzip or python3"
  fi
}

require_linux() {
  if [ "$(uname -s)" != "Linux" ]; then
    fatal "This script only supports Linux"
  fi
}

run_root() {
  if [ "$(id -u)" -eq 0 ]; then
    "$@"
  elif command_exists sudo; then
    sudo "$@"
  else
    fatal "Root privilege is required. Please install sudo or run as root"
  fi
}

detect_arch() {
  case "$(uname -m)" in
    x86_64 | amd64)
      printf 'amd64\n'
      ;;
    aarch64 | arm64)
      printf 'arm64\n'
      ;;
    i386 | i686)
      printf '386\n'
      ;;
    *)
      fatal "Unsupported architecture: $(uname -m)"
      ;;
  esac
}

normalize_version() {
  local version="$1"

  version="${version#v}"
  if [[ ! "$version" =~ ^[0-9]+[.][0-9]+[.][0-9]+$ ]]; then
    fatal "Invalid Vault version: $1"
  fi

  printf '%s\n' "$version"
}

curl_stdout() {
  local url="$1"

  curl --fail --location --show-error --silent --connect-timeout 10 --max-time 60 "$url"
}

curl_download() {
  local url="$1"
  local output="$2"
  local curl_args=(
    --fail
    --location
    --show-error
    --retry 3
    --connect-timeout 10
    --max-time 300
    --output "$output"
  )

  if [ -t 2 ]; then
    curl_args+=(--progress-bar)
  else
    curl_args+=(--silent)
  fi

  curl "${curl_args[@]}" "$url"
}

fetch_latest_version() {
  local latest

  latest="$(
    curl_stdout "$RELEASE_INDEX_URL" |
      sed -n 's#.*href="/vault/\([0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*\)/".*#\1#p' |
      head -n 1
  )"

  if [ -z "$latest" ]; then
    return 1
  fi

  normalize_version "$latest"
}

resolve_version() {
  local requested="$1"
  local latest

  if [ -n "$requested" ] && [ "$requested" != "latest" ]; then
    normalize_version "$requested"
    return
  fi

  if latest="$(fetch_latest_version)"; then
    log_info "Resolved latest Vault version: ${latest}" >&2
    printf '%s\n' "$latest"
    return
  fi

  log_warn "Failed to resolve latest Vault version, fallback to ${DEFAULT_VAULT_VERSION}"
  printf '%s\n' "$DEFAULT_VAULT_VERSION"
}

checksum_file() {
  local file="$1"

  if command_exists sha256sum; then
    sha256sum "$file" | awk '{print $1}'
  else
    shasum -a 256 "$file" | awk '{print $1}'
  fi
}

verify_checksum() {
  local zip_file="$1"
  local sums_file="$2"
  local zip_name
  local expected
  local actual

  zip_name="$(basename "$zip_file")"
  expected="$(awk -v file="$zip_name" '$2 == file {print $1; exit}' "$sums_file")"
  if [ -z "$expected" ]; then
    fatal "Checksum entry not found for ${zip_name}"
  fi

  actual="$(checksum_file "$zip_file")"
  if [ "$expected" != "$actual" ]; then
    fatal "Checksum mismatch for ${zip_name}"
  fi

  log_info "Checksum verified: ${zip_name}"
}

extract_zip() {
  local zip_file="$1"
  local output_dir="$2"

  if command_exists unzip; then
    unzip -q "$zip_file" -d "$output_dir"
    return
  fi

  python3 -m zipfile -e "$zip_file" "$output_dir"
}

create_install_tmpdir() {
  local prefix="$1"
  local parent="${TMPDIR:-/var/tmp}"
  local tmpdir

  if [ ! -d "$parent" ]; then
    fatal "Temporary directory parent not found: ${parent}. Set TMPDIR to a writable directory with enough space"
  fi
  if [ ! -w "$parent" ]; then
    fatal "Temporary directory parent is not writable: ${parent}. Set TMPDIR to a writable directory with enough space"
  fi

  if ! tmpdir="$(mktemp -d "${parent%/}/${prefix}.XXXXXXXXXX")"; then
    fatal "Failed to create temporary directory under ${parent}"
  fi
  log_info "Using install temporary directory: ${tmpdir}"
  printf '%s\n' "$tmpdir"
}

hcl_string() {
  local value="$1"

  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '"%s"' "$value"
}

validate_tls_value() {
  local name="$1"
  local value="$2"

  if [ -z "$value" ] || [[ "$value" == *$'\n'* ]] || [[ "$value" == *$'\r'* ]]; then
    fatal "Invalid ${name}: ${value}"
  fi
}

add_tls_dns_name() {
  local value="$1"
  local existing

  validate_tls_value "TLS DNS SAN" "$value"
  if [ "${#INSTALL_TLS_DNS_NAMES[@]}" -gt 0 ]; then
    for existing in "${INSTALL_TLS_DNS_NAMES[@]}"; do
      [ "$existing" != "$value" ] || return 0
    done
  fi
  INSTALL_TLS_DNS_NAMES+=("$value")
}

add_tls_ip_address() {
  local value="$1"
  local existing

  validate_tls_value "TLS IP SAN" "$value"
  if [ "${#INSTALL_TLS_IP_ADDRESSES[@]}" -gt 0 ]; then
    for existing in "${INSTALL_TLS_IP_ADDRESSES[@]}"; do
      [ "$existing" != "$value" ] || return 0
    done
  fi
  INSTALL_TLS_IP_ADDRESSES+=("$value")
}

looks_like_ip_address() {
  local value="$1"

  [[ "$value" == *:* ]] || [[ "$value" =~ ^[0-9.]+$ ]]
}

url_host() {
  local url="$1"
  local rest
  local host

  case "$url" in
    *://*)
      rest="${url#*://}"
      ;;
    *)
      return 1
      ;;
  esac

  host="${rest%%/*}"
  if [[ "$host" == \[*\] ]]; then
    host="${host#\[}"
    host="${host%\]}"
  else
    host="${host%%:*}"
  fi

  [ -n "$host" ] || return 1
  printf '%s\n' "$host"
}

add_default_tls_sans() {
  local api_addr="$1"
  local cluster_addr="${2:-}"
  local host_name
  local host_fqdn
  local api_host
  local cluster_host

  add_tls_dns_name "localhost"
  add_tls_dns_name "vault-server"
  host_name="$(hostname 2>/dev/null || true)"
  [ -z "$host_name" ] || add_tls_dns_name "$host_name"
  host_fqdn="$(hostname -f 2>/dev/null || true)"
  [ -z "$host_fqdn" ] || add_tls_dns_name "$host_fqdn"
  add_tls_ip_address "127.0.0.1"

  if api_host="$(url_host "$api_addr")"; then
    if looks_like_ip_address "$api_host"; then
      add_tls_ip_address "$api_host"
    else
      add_tls_dns_name "$api_host"
    fi
  fi
  if [ -n "$cluster_addr" ] && cluster_host="$(url_host "$cluster_addr")"; then
    if looks_like_ip_address "$cluster_host"; then
      add_tls_ip_address "$cluster_host"
    else
      add_tls_dns_name "$cluster_host"
    fi
  fi
}

install_self_signed_tls_cert() {
  local tmpdir="$1"
  local common_name="$2"
  local tls_tmp="${tmpdir}/tls"
  local ca_conf="${tls_tmp}/ca.conf"
  local server_conf="${tls_tmp}/server.conf"
  local server_ext_conf="${tls_tmp}/server-ext.conf"
  local dns_index=1
  local ip_index=1
  local value

  validate_tls_value "TLS common name" "$common_name"
  require_command openssl
  install -d -m 0700 "$tls_tmp"

  cat >"$ca_conf" <<EOF
[req]
distinguished_name = dn
x509_extensions = v3_ca
prompt = no

[dn]
C = CN
ST = HongKong
L = HongKong
O = Vault
OU = Vault CA
CN = vault-root-ca

[v3_ca]
subjectKeyIdentifier = hash
authorityKeyIdentifier = keyid:always,issuer
basicConstraints = critical, CA:true
keyUsage = critical, keyCertSign, cRLSign
EOF

  # TLS 证书默认覆盖本机访问地址，额外 SAN 通过安装参数传入。
  {
    cat <<EOF
[req]
distinguished_name = dn
req_extensions = v3_req
prompt = no

[dn]
C = CN
ST = HongKong
L = HongKong
O = Vault
OU = Vault
CN = ${common_name}

[v3_req]
basicConstraints = CA:false
keyUsage = critical, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth
subjectAltName = @alt_names

[alt_names]
EOF
    if [ "${#INSTALL_TLS_DNS_NAMES[@]}" -gt 0 ]; then
      for value in "${INSTALL_TLS_DNS_NAMES[@]}"; do
        printf 'DNS.%s = %s\n' "$dns_index" "$value"
        dns_index=$((dns_index + 1))
      done
    fi
    if [ "${#INSTALL_TLS_IP_ADDRESSES[@]}" -gt 0 ]; then
      for value in "${INSTALL_TLS_IP_ADDRESSES[@]}"; do
        printf 'IP.%s = %s\n' "$ip_index" "$value"
        ip_index=$((ip_index + 1))
      done
    fi
  } >"$server_conf"

  {
    cat <<EOF
authorityKeyIdentifier = keyid,issuer
basicConstraints = CA:false
keyUsage = critical, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth
subjectAltName = @alt_names

[alt_names]
EOF
    dns_index=1
    if [ "${#INSTALL_TLS_DNS_NAMES[@]}" -gt 0 ]; then
      for value in "${INSTALL_TLS_DNS_NAMES[@]}"; do
        printf 'DNS.%s = %s\n' "$dns_index" "$value"
        dns_index=$((dns_index + 1))
      done
    fi
    ip_index=1
    if [ "${#INSTALL_TLS_IP_ADDRESSES[@]}" -gt 0 ]; then
      for value in "${INSTALL_TLS_IP_ADDRESSES[@]}"; do
        printf 'IP.%s = %s\n' "$ip_index" "$value"
        ip_index=$((ip_index + 1))
      done
    fi
  } >"$server_ext_conf"

  log_info "Generating self-signed Vault TLS certificate"
  openssl genrsa -out "${tls_tmp}/ca.key" 4096 >/dev/null 2>&1
  openssl req -x509 -new -nodes -key "${tls_tmp}/ca.key" -days 3650 -out "${tls_tmp}/ca.crt" -config "$ca_conf" -extensions v3_ca >/dev/null 2>&1
  openssl genrsa -out "${tls_tmp}/server.key" 4096 >/dev/null 2>&1
  openssl req -new -key "${tls_tmp}/server.key" -out "${tls_tmp}/server.csr" -config "$server_conf" >/dev/null 2>&1
  openssl x509 -req -in "${tls_tmp}/server.csr" -CA "${tls_tmp}/ca.crt" -CAkey "${tls_tmp}/ca.key" -CAcreateserial -out "${tls_tmp}/server.crt" -days 3650 -extfile "$server_ext_conf" >/dev/null 2>&1

  run_root install -d -m 0755 -o root -g root "$TLS_DIR"
  run_root install -m 0600 -o root -g root "${tls_tmp}/ca.key" "${TLS_DIR}/ca.key"
  run_root install -m 0644 -o root -g root "${tls_tmp}/ca.crt" "$TLS_CA_CERT_FILE"
  run_root install -m 0644 -o root -g root "${tls_tmp}/server.crt" "$TLS_CERT_FILE"
  run_root install -m 0640 -o root -g "$VAULT_GROUP" "${tls_tmp}/server.key" "$TLS_KEY_FILE"
  log_info "Vault TLS certificate installed: ${TLS_CERT_FILE}"
}

is_managed_file() {
  local path="$1"
  local first_line

  [ -f "$path" ] || return 1
  first_line="$(sed -n '1p' "$path")"
  [ "$first_line" = "$MANAGED_MARKER" ] || [ "$first_line" = "$PRE_RENAME_MANAGED_MARKER" ] || [ "$first_line" = "$LEGACY_MANAGED_MARKER" ]
}

ensure_managed_or_absent() {
  local path="$1"

  if [ -e "$path" ] && ! is_managed_file "$path"; then
    fatal "Refuse to manage non-managed file: ${path}"
  fi
}

safe_remove_path() {
  local path="$1"

  case "$path" in
    "" | "/" | "/usr" | "/usr/local" | "/usr/local/bin" | "/etc" | "/opt")
      fatal "Refuse to remove unsafe path: ${path}"
      ;;
  esac

  if [ -e "$path" ] || [ -L "$path" ]; then
    run_root rm -rf -- "$path"
  fi
}

current_script_path() {
  local source="${BASH_SOURCE[0]}"
  local dir

  while [ -L "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
    source="$(readlink "$source")"
    case "$source" in
      /*)
        ;;
      *)
        source="${dir}/${source}"
        ;;
    esac
  done

  dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
  printf '%s/%s\n' "$dir" "$(basename "$source")"
}

write_tool_manifest() {
  local tmpdir="$1"
  local manifest_file="${tmpdir}/MANIFEST.sha256"
  local path
  local name

  : >"$manifest_file"
  for name in vault-manager VERSION; do
    path="${TOOL_DIR}/${name}"
    if [ -f "$path" ]; then
      printf '%s  %s\n' "$(checksum_file "$path")" "$name" >>"$manifest_file"
    fi
  done

  run_root install -m 0644 -o root -g root "$manifest_file" "$TOOL_MANIFEST_FILE"
}

write_install_metadata() {
  local version="$1"
  local tmpdir="$2"
  local metadata_file="${tmpdir}/install.json"
  local installed_at
  local manifest_sha=""

  installed_at="$(date '+%Y-%m-%dT%H:%M:%S%z' 2>/dev/null || date)"
  if [ -f "$TOOL_MANIFEST_FILE" ]; then
    manifest_sha="$(checksum_file "$TOOL_MANIFEST_FILE")"
  fi

  {
    printf '{\n'
    printf '  "tool": "vault-manager",\n'
    printf '  "root_dir": %s,\n' "$(json_string "$VAULT_ROOT_DIR")"
    printf '  "tool_dir": %s,\n' "$(json_string "$TOOL_DIR")"
    printf '  "manager_path": %s,\n' "$(json_string "$TOOL_PATH")"
    printf '  "manager_entry": %s,\n' "$(json_string "$TOOL_ENTRY")"
    printf '  "vault_binary": %s,\n' "$(json_string "$BIN_PATH")"
    printf '  "vault_entry": %s,\n' "$(json_string "$BIN_ENTRY")"
    printf '  "config_file": %s,\n' "$(json_string "$CONFIG_FILE")"
    printf '  "client_env_file": %s,\n' "$(json_string "$CLIENT_ENV_FILE")"
    printf '  "tls_dir": %s,\n' "$(json_string "$TLS_DIR")"
    printf '  "data_dir": %s,\n' "$(json_string "$DATA_DIR")"
    printf '  "state_dir": %s,\n' "$(json_string "$STATE_DIR")"
    printf '  "service": %s,\n' "$(json_string "$SYSTEMD_SERVICE")"
    printf '  "vault_version": %s,\n' "$(json_string "$version")"
    printf '  "installed_at": %s,\n' "$(json_string "$installed_at")"
    printf '  "manifest_file": %s,\n' "$(json_string "$TOOL_MANIFEST_FILE")"
    printf '  "manifest_sha256": %s,\n' "$(json_string "$manifest_sha")"
    printf '  "audit_log": %s\n' "$(json_string "$AUDIT_LOG_FILE")"
    printf '}\n'
  } >"$metadata_file"

  run_root install -d -m 0750 -o root -g root "$TOOL_STATE_DIR"
  run_root install -m 0644 -o root -g root "$metadata_file" "$INSTALL_METADATA_FILE"
}

write_state_pointer() {
  local tmpdir="$1"
  local pointer_file="${tmpdir}/managed-by-vault-init-tools"

  {
    printf 'Managed by vault-manager\n'
    printf 'Install metadata: %s\n' "$INSTALL_METADATA_FILE"
    printf 'Tool dir: %s\n' "$TOOL_DIR"
    printf 'Config file: %s\n' "$CONFIG_FILE"
    printf 'Audit log: %s\n' "$AUDIT_LOG_FILE"
  } >"$pointer_file"

  run_root install -m 0644 -o root -g root "$pointer_file" "$STATE_POINTER_FILE"
}

install_tool_snapshot() {
  local version="$1"
  local tmpdir="$2"
  local manager_src
  local snapshot_dir="${tmpdir}/tool-snapshot"
  local version_file="${snapshot_dir}/VERSION"

  manager_src="$(current_script_path)"

  log_info "Installing Vault init tools snapshot: ${TOOL_DIR}"
  install -d -m 0755 "$snapshot_dir"
  install -m 0755 "$manager_src" "${snapshot_dir}/vault-manager"

  {
    printf 'tool=vault-manager\n'
    printf 'vault_version=%s\n' "$version"
    printf 'installed_at=%s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z' 2>/dev/null || date)"
    printf 'source=%s\n' "$manager_src"
  } >"$version_file"

  run_root install -d -m 0755 -o root -g root "$BIN_DIR"
  run_root install -d -m 0755 -o root -g root "$TOOL_DIR"
  safe_remove_path "${TOOL_DIR}/manager.sh"
  run_root install -m 0755 -o root -g root "${snapshot_dir}/vault-manager" "${TOOL_DIR}/vault-manager"
  run_root install -m 0644 -o root -g root "$version_file" "$TOOL_VERSION_FILE"

  write_tool_manifest "$tmpdir"
  write_install_metadata "$version" "$tmpdir"
  write_state_pointer "$tmpdir"

  run_root ln -sfn "${TOOL_DIR}/vault-manager" "$TOOL_PATH"
  run_root install -d -m 0755 -o root -g root "$(dirname "$TOOL_ENTRY")"
  run_root ln -sfn "$TOOL_PATH" "$TOOL_ENTRY"
  if [ -L "$LEGACY_TOOL_ENTRY" ]; then
    safe_remove_path "$LEGACY_TOOL_ENTRY"
  fi

  log_info "Vault manager path installed: ${TOOL_PATH}"
  log_info "Vault manager entry installed: ${TOOL_ENTRY}"
  log_info "Vault install metadata written: ${INSTALL_METADATA_FILE}"
}

read_installed_vault_version() {
  local version=""

  if [ -r "$INSTALL_METADATA_FILE" ]; then
    version="$(
      sed -n 's/^[[:space:]]*"vault_version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$INSTALL_METADATA_FILE" |
        head -n 1
    )"
  fi
  if [ -z "$version" ] && [ -r "$TOOL_VERSION_FILE" ]; then
    version="$(sed -n 's/^vault_version=//p' "$TOOL_VERSION_FILE" | head -n 1)"
  fi

  printf '%s\n' "${version:-unknown}"
}

tools_update() {
  local version=""
  local tmpdir=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --vault-version)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --vault-version"
        version="$(normalize_version "$1")"
        ;;
      -h | --help)
        tools_usage
        exit 0
        ;;
      *)
        fatal "Unknown tools update option: $1"
        ;;
    esac
    shift
  done

  require_linux
  require_command install
  require_command mktemp
  require_command readlink
  require_command sed
  require_any_checksum_command

  if [ -z "$version" ]; then
    version="$(read_installed_vault_version)"
  fi
  if [ "$version" = "unknown" ]; then
    log_warn "Installed Vault version metadata not found; recording unknown"
  fi

  tmpdir="$(create_install_tmpdir vault-tools-update)"
  if ! install_tool_snapshot "$version" "$tmpdir"; then
    rm -rf -- "$tmpdir"
    return 1
  fi
  rm -rf -- "$tmpdir"
  log_info "Vault init tools updated"
}

remove_tool_snapshot() {
  log_info "Removing Vault init tools"
  safe_remove_path "$TOOL_ENTRY"
  if [ -L "$LEGACY_TOOL_ENTRY" ]; then
    safe_remove_path "$LEGACY_TOOL_ENTRY"
  fi
  safe_remove_path "$TOOL_PATH"
  safe_remove_path "$TOOL_DIR"
}

purge_tool_state() {
  log_warn "Purging Vault init tool metadata and audit logs"
  safe_remove_path "$TOOL_STATE_DIR"
  safe_remove_path "$TOOL_LOG_DIR"
  AUDIT_DISABLE_AFTER_PURGE=1
}

ensure_vault_user() {
  local shell_path="/usr/sbin/nologin"

  if ! getent group "$VAULT_GROUP" >/dev/null 2>&1; then
    log_info "Creating system group: ${VAULT_GROUP}"
    run_root groupadd --system "$VAULT_GROUP"
  fi

  if id "$VAULT_USER" >/dev/null 2>&1; then
    return
  fi

  if [ ! -x "$shell_path" ]; then
    shell_path="/bin/false"
  fi

  log_info "Creating system user: ${VAULT_USER}"
  run_root useradd --system --gid "$VAULT_GROUP" --home "$STATE_DIR" --shell "$shell_path" "$VAULT_USER"
}

install_vault_dir() {
  local mode="$1"
  local owner="$2"
  local group="$3"
  local path="$4"

  if [ -e "$path" ] && [ ! -d "$path" ]; then
    fatal "Path exists but is not a directory: $path"
  fi

  if ! run_root install -d -m "$mode" -o "$owner" -g "$group" "$path"; then
    fatal "Failed to create directory: $path"
  fi
}

install_directories() {
  log_info "Creating Vault directories"
  install_vault_dir 0755 root root "$VAULT_ROOT_DIR"
  install_vault_dir 0755 root root "$BIN_DIR"
  install_vault_dir 0755 root root "${VAULT_ROOT_DIR}/etc"
  install_vault_dir 0755 root root "${VAULT_ROOT_DIR}/data"
  install_vault_dir 0755 root root "${VAULT_ROOT_DIR}/lib"
  install_vault_dir 0750 root root "${VAULT_ROOT_DIR}/log"
  install_vault_dir 0755 root root "$CONFIG_DIR"
  install_vault_dir 0755 root root "$TLS_DIR"
  install_vault_dir 0750 "$VAULT_USER" "$VAULT_GROUP" "$STATE_DIR"
  install_vault_dir 0750 "$VAULT_USER" "$VAULT_GROUP" "$DATA_DIR"
  install_vault_dir 0700 root root "$INIT_DIR"
}

download_vault() {
  local version="$1"
  local arch="$2"
  local tmpdir="$3"
  local zip_name="vault_${version}_linux_${arch}.zip"
  local sums_name="vault_${version}_SHA256SUMS"
  local base_url="https://releases.hashicorp.com/vault/${version}"
  local zip_file="${tmpdir}/${zip_name}"
  local sums_file="${tmpdir}/${sums_name}"

  log_info "Downloading Vault ${version} for linux_${arch}"
  curl_download "${base_url}/${zip_name}" "$zip_file"
  curl_download "${base_url}/${sums_name}" "$sums_file"
  verify_checksum "$zip_file" "$sums_file"

  extract_zip "$zip_file" "${tmpdir}/extract"
  if [ ! -f "${tmpdir}/extract/vault" ]; then
    fatal "Vault binary not found in archive"
  fi
}

install_binary() {
  local tmpdir="$1"

  log_info "Installing binary: ${BIN_PATH}"
  run_root install -d -m 0755 -o root -g root "$BIN_DIR"
  run_root install -m 0755 -o root -g root "${tmpdir}/extract/vault" "$BIN_PATH"
  run_root install -d -m 0755 -o root -g root "$(dirname "$BIN_ENTRY")"
  run_root ln -sfn "$BIN_PATH" "$BIN_ENTRY"
  log_info "Vault binary entry installed: ${BIN_ENTRY}"
  "$BIN_PATH" version
}

write_vault_config() {
  local tmpdir="$1"
  local listen_address="$2"
  local cluster_address="$3"
  local api_addr="$4"
  local cluster_addr="$5"
  local tls_disable="$6"
  local tls_cert_file="$7"
  local tls_key_file="$8"
  local config_file="${tmpdir}/config.hcl"
  local node_id

  ensure_managed_or_absent "$CONFIG_FILE"
  node_id="vault-$(hostname | tr -cd 'A-Za-z0-9_.-' | cut -c 1-48)"
  [ -n "$node_id" ] || node_id="vault-node"

  if [ "$tls_disable" = "false" ]; then
    [ -n "$tls_cert_file" ] || fatal "install requires a TLS certificate file when TLS is enabled"
    [ -n "$tls_key_file" ] || fatal "install requires a TLS key file when TLS is enabled"
  fi

  {
    printf '%s\n' "$MANAGED_MARKER"
    printf 'ui = true\n'
    printf 'disable_mlock = true\n'
    printf 'api_addr = %s\n' "$(hcl_string "$api_addr")"
    printf 'cluster_addr = %s\n' "$(hcl_string "$cluster_addr")"
    printf '\n'
    printf 'storage "raft" {\n'
    printf '  path    = %s\n' "$(hcl_string "$DATA_DIR")"
    printf '  node_id = %s\n' "$(hcl_string "$node_id")"
    printf '}\n'
    printf '\n'
    printf 'listener "tcp" {\n'
    printf '  address         = %s\n' "$(hcl_string "$listen_address")"
    printf '  cluster_address = %s\n' "$(hcl_string "$cluster_address")"
    printf '  tls_disable     = %s\n' "$tls_disable"
    [ -z "$tls_cert_file" ] || printf '  tls_cert_file   = %s\n' "$(hcl_string "$tls_cert_file")"
    [ -z "$tls_key_file" ] || printf '  tls_key_file    = %s\n' "$(hcl_string "$tls_key_file")"
    printf '}\n'
  } >"$config_file"

  log_info "Installing Vault config: ${CONFIG_FILE}"
  run_root install -m 0640 -o root -g "$VAULT_GROUP" "$config_file" "$CONFIG_FILE"
}

write_client_env() {
  local tmpdir="$1"
  local api_addr="$2"
  local tls_ca_cert_file="$3"
  local client_env_file="${tmpdir}/client.env"

  {
    printf 'VAULT_ADDR=%s\n' "$api_addr"
    [ -z "$tls_ca_cert_file" ] || printf 'VAULT_CACERT=%s\n' "$tls_ca_cert_file"
  } >"$client_env_file"

  log_info "Installing Vault client defaults: ${CLIENT_ENV_FILE}"
  run_root install -m 0644 -o root -g root "$client_env_file" "$CLIENT_ENV_FILE"
}

write_systemd_service() {
  local tmpdir="$1"
  local service_file="${tmpdir}/vault.service"

  cat >"$service_file" <<EOF
[Unit]
Description=Vault
Documentation=https://developer.hashicorp.com/vault/docs
Wants=network-online.target
After=network-online.target

[Service]
User=${VAULT_USER}
Group=${VAULT_GROUP}
ExecReload=/bin/kill -HUP \$MAINPID
ExecStart=${BIN_PATH} server -config=${CONFIG_FILE}
KillSignal=SIGINT
LimitNOFILE=65536
Restart=on-failure
RestartSec=2
TimeoutStopSec=30
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=full
ProtectHome=read-only
ReadWritePaths=${STATE_DIR}

[Install]
WantedBy=multi-user.target
EOF

  log_info "Installing systemd service: ${SYSTEMD_SERVICE}"
  run_root install -m 0644 -o root -g root "$service_file" "$SYSTEMD_SERVICE"
}

wait_for_vault_api() {
  local address="$1"
  local ca_cert="${2:-}"
  local url="${address%/}/v1/sys/health"
  local attempt=1
  local code
  local -a curl_args

  require_command curl
  log_info "Waiting for Vault HTTP API"
  curl_args=(--noproxy '*' --silent --output /dev/null --write-out '%{http_code}' --max-time 3)
  [ -z "$ca_cert" ] || curl_args+=(--cacert "$ca_cert")
  while [ "$attempt" -le 60 ]; do
    code="$(curl "${curl_args[@]}" "$url" 2>/dev/null || true)"
    case "$code" in
      200 | 429 | 472 | 473 | 501 | 503)
        return
        ;;
    esac

    if command_exists systemctl && ! run_root systemctl is-active --quiet vault; then
      log_error "Vault service is not active"
      if command_exists journalctl; then
        run_root journalctl -u vault -n 80 --no-pager || true
      fi
      exit 1
    fi

    sleep 2
    attempt=$((attempt + 1))
  done

  if command_exists journalctl; then
    run_root journalctl -u vault -n 80 --no-pager || true
  fi
  fatal "Timed out waiting for Vault HTTP API: ${url}"
}

install_vault() {
  local requested_version=""
  local version
  local arch
  local tmpdir
  local listen_address="0.0.0.0:8200"
  local cluster_address="0.0.0.0:8201"
  local api_addr="$DEFAULT_VAULT_ADDR"
  local cluster_addr="http://127.0.0.1:8201"
  local api_addr_set=0
  local cluster_addr_set=0
  local tls_mode="disabled"
  local tls_no_tls_set=0
  local tls_auto_set=0
  local tls_custom_options_set=0
  local tls_disable="true"
  local tls_cert_file=""
  local tls_key_file=""
  local tls_ca_cert_file=""
  local tls_common_name="vault-server"
  local tls_auto_options_set=0

  INSTALL_TLS_DNS_NAMES=()
  INSTALL_TLS_IP_ADDRESSES=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --version)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --version"
        requested_version="$1"
        ;;
      --listen-address)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --listen-address"
        listen_address="$1"
        ;;
      --cluster-address)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --cluster-address"
        cluster_address="$1"
        ;;
      --api-addr)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --api-addr"
        api_addr="$1"
        api_addr_set=1
        ;;
      --cluster-addr)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --cluster-addr"
        cluster_addr="$1"
        cluster_addr_set=1
        ;;
      --no-tls)
        tls_no_tls_set=1
        ;;
      --tls-auto)
        tls_auto_set=1
        ;;
      --tls-cert-file)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --tls-cert-file"
        tls_cert_file="$1"
        tls_custom_options_set=1
        ;;
      --tls-key-file)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --tls-key-file"
        tls_key_file="$1"
        tls_custom_options_set=1
        ;;
      --tls-ca-cert-file)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --tls-ca-cert-file"
        tls_ca_cert_file="$1"
        tls_custom_options_set=1
        ;;
      --tls-dns)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --tls-dns"
        add_tls_dns_name "$1"
        tls_auto_options_set=1
        ;;
      --tls-ip)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --tls-ip"
        add_tls_ip_address "$1"
        tls_auto_options_set=1
        ;;
      --tls-common-name)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --tls-common-name"
        validate_tls_value "TLS common name" "$1"
        tls_common_name="$1"
        tls_auto_options_set=1
        ;;
      -h | --help)
        install_usage
        exit 0
        ;;
      -*)
        fatal "Unknown install option: $1"
        ;;
      *)
        if [ -n "$requested_version" ]; then
          fatal "Unexpected argument: $1"
        fi
        requested_version="$1"
        ;;
    esac
    shift
  done

  if [ "$tls_no_tls_set" -eq 1 ] && { [ "$tls_auto_set" -eq 1 ] || [ "$tls_custom_options_set" -eq 1 ] || [ "$tls_auto_options_set" -eq 1 ]; }; then
    fatal "--no-tls cannot be used with TLS options"
  fi
  if [ "$tls_auto_set" -eq 1 ] && [ "$tls_custom_options_set" -eq 1 ]; then
    fatal "--tls-auto cannot be used with custom TLS certificate options"
  fi
  if [ "$tls_auto_options_set" -eq 1 ] && [ "$tls_auto_set" -ne 1 ]; then
    fatal "--tls-dns, --tls-ip and --tls-common-name require --tls-auto"
  fi
  if [ "$tls_auto_set" -eq 1 ]; then
    tls_mode="auto"
  elif [ "$tls_custom_options_set" -eq 1 ]; then
    tls_mode="custom"
  fi

  if [ "$tls_mode" != "disabled" ]; then
    tls_disable="false"
    if [ "$api_addr_set" -eq 0 ]; then
      api_addr="https://127.0.0.1:8200"
    fi
    if [ "$cluster_addr_set" -eq 0 ]; then
      cluster_addr="https://127.0.0.1:8201"
    fi
    case "$api_addr" in
      https://*)
        ;;
      *)
        fatal "TLS is enabled; --api-addr must use https://"
        ;;
    esac
    case "$cluster_addr" in
      https://*)
        ;;
      *)
        fatal "TLS is enabled; --cluster-addr must use https://"
        ;;
    esac
    if [ "$tls_mode" = "custom" ] && { [ -z "$tls_cert_file" ] || [ -z "$tls_key_file" ]; }; then
      fatal "TLS custom certificate requires both --tls-cert-file and --tls-key-file"
    fi
    if [ -n "$tls_cert_file" ]; then
      [ -f "$tls_cert_file" ] || fatal "TLS certificate file not found: ${tls_cert_file}"
      [ -f "$tls_key_file" ] || fatal "TLS key file not found: ${tls_key_file}"
    fi
    if [ -n "$tls_ca_cert_file" ]; then
      [ -f "$tls_ca_cert_file" ] || fatal "TLS CA certificate file not found: ${tls_ca_cert_file}"
    fi
  fi

  require_linux
  require_command curl
  require_command awk
  require_command sed
  require_command head
  require_command mktemp
  require_command install
  require_command readlink
  require_command systemctl
  require_command useradd
  require_command groupadd
  require_any_checksum_command
  require_zip_extractor

  version="$(resolve_version "$requested_version")"
  arch="$(detect_arch)"
  TMPDIR_TO_CLEAN="$(create_install_tmpdir vault-install)"
  tmpdir="$TMPDIR_TO_CLEAN"
  trap cleanup EXIT

  download_vault "$version" "$arch" "$tmpdir"
  install_binary "$tmpdir"
  ensure_vault_user
  install_directories
  if [ "$tls_mode" = "auto" ]; then
    add_default_tls_sans "$api_addr" "$cluster_addr"
    install_self_signed_tls_cert "$tmpdir" "$tls_common_name"
    tls_cert_file="$TLS_CERT_FILE"
    tls_key_file="$TLS_KEY_FILE"
    tls_ca_cert_file="$TLS_CA_CERT_FILE"
  fi
  write_vault_config "$tmpdir" "$listen_address" "$cluster_address" "$api_addr" "$cluster_addr" "$tls_disable" "$tls_cert_file" "$tls_key_file"
  write_client_env "$tmpdir" "$api_addr" "$tls_ca_cert_file"
  write_systemd_service "$tmpdir"
  install_tool_snapshot "$version" "$tmpdir"

  log_info "Enabling Vault service"
  run_root systemctl daemon-reload
  run_root systemctl enable vault
  run_root systemctl restart vault
  wait_for_vault_api "$api_addr" "$tls_ca_cert_file"

  log_info "Vault installation completed"
}

uninstall_vault() {
  local purge_data=0
  local remove_tools=0
  local purge=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --purge-data)
        purge_data=1
        ;;
      --remove-tools)
        remove_tools=1
        ;;
      --purge)
        purge_data=1
        remove_tools=1
        purge=1
        ;;
      -h | --help)
        uninstall_usage
        exit 0
        ;;
      *)
        fatal "Unknown uninstall option: $1"
        ;;
    esac
    shift
  done

  require_linux
  require_command systemctl
  require_command getent

  log_info "Stopping Vault service"
  run_root systemctl stop vault 2>/dev/null || true
  run_root systemctl disable vault 2>/dev/null || true

  log_info "Removing Vault service, binary and config"
  safe_remove_path "$SYSTEMD_SERVICE"
  safe_remove_path "$BIN_ENTRY"
  safe_remove_path "$BIN_PATH"
  safe_remove_path "$CONFIG_DIR"

  if [ "$purge_data" -eq 1 ]; then
    log_warn "Purging Vault state directory: ${STATE_DIR}"
    safe_remove_path "$STATE_DIR"
    log_warn "Purging Vault init directory: ${INIT_DIR}"
    safe_remove_path "$INIT_DIR"
    if id "$VAULT_USER" >/dev/null 2>&1; then
      log_info "Removing system user: ${VAULT_USER}"
      run_root userdel "$VAULT_USER" || log_warn "Failed to remove user: ${VAULT_USER}"
    fi
    if getent group "$VAULT_GROUP" >/dev/null 2>&1; then
      log_info "Removing system group: ${VAULT_GROUP}"
      run_root groupdel "$VAULT_GROUP" || log_warn "Failed to remove group: ${VAULT_GROUP}"
    fi
  else
    log_warn "Vault state preserved: ${STATE_DIR}. Use --purge-data to remove it"
    log_warn "Vault init output preserved: ${INIT_DIR}. Use --purge-data to remove it"
  fi

  if [ "$remove_tools" -eq 1 ]; then
    remove_tool_snapshot
  else
    log_warn "Vault init tools preserved: ${TOOL_DIR}. Use --remove-tools to remove them"
  fi

  if [ "$purge" -eq 1 ]; then
    remove_vault_acl_env_file
    purge_tool_state
  else
    log_warn "Vault init tool metadata preserved: ${TOOL_STATE_DIR}"
    log_warn "Vault init tool audit logs preserved: ${TOOL_LOG_DIR}"
  fi

  run_root systemctl daemon-reload
  run_root systemctl reset-failed vault 2>/dev/null || true
  log_info "Vault uninstallation completed"
}

reset_vault_cli_opts() {
  VC_ADDR="$DEFAULT_VAULT_ADDR"
  VC_CACERT=""
  VC_NAMESPACE="${VAULT_NAMESPACE:-}"
  VC_TOKEN_FILE=""
  load_client_env_defaults
  VC_ADDR="${VAULT_ADDR:-$VC_ADDR}"
  VC_CACERT="${VAULT_CACERT:-$VC_CACERT}"
}

load_client_env_defaults() {
  local key
  local value

  [ -r "$CLIENT_ENV_FILE" ] || return 0
  while IFS='=' read -r key value; do
    case "$key" in
      VAULT_ADDR)
        [ -z "$value" ] || VC_ADDR="$value"
        ;;
      VAULT_CACERT)
        [ -z "$value" ] || VC_CACERT="$value"
        ;;
    esac
  done <"$CLIENT_ENV_FILE"
}

read_vault_token_file() {
  local path="$1"

  [ -f "$path" ] || fatal "Token file not found: ${path}"
  require_command python3
  python3 - "$path" <<'PY'
import json
import sys

path = sys.argv[1]
raw = open(path, "r", encoding="utf-8").read().strip()
try:
    data = json.loads(raw)
except json.JSONDecodeError:
    print(raw.splitlines()[0] if raw else "")
    raise SystemExit

for key in ("root_token", "initial_root_token", "token"):
    value = data.get(key)
    if value:
        print(value)
        raise SystemExit
print("")
PY
}

target_vault_acl_info() {
  local target_user="${SUDO_USER:-$(id -un)}"

  require_command python3
  python3 - "$target_user" <<'PY'
import os
import pwd
import sys

target_user = sys.argv[1]
try:
    info = pwd.getpwnam(target_user)
except KeyError:
    info = pwd.getpwuid(os.getuid())

home = info.pw_dir or os.path.expanduser("~")
print(info.pw_name)
print(info.pw_uid)
print(info.pw_gid)
print(home)
print(os.path.join(home, "vault.acl"))
PY
}

write_vault_acl_env_file() {
  local init_json="$1"
  local token=""
  local target_user=""
  local target_uid=""
  local target_gid=""
  local target_home=""
  local acl_file=""
  local tmp=""

  token="$(read_vault_token_file "$init_json")"
  if [ -z "$token" ]; then
    log_warn "Vault root token not found in init output; skip vault.acl generation"
    return 0
  fi

  {
    IFS= read -r target_user
    IFS= read -r target_uid
    IFS= read -r target_gid
    IFS= read -r target_home
    IFS= read -r acl_file
  } < <(target_vault_acl_info)

  if [ ! -d "$target_home" ]; then
    log_warn "Target home directory not found; skip vault.acl generation: ${target_home}"
    return 0
  fi

  tmp="$(mktemp)"
  {
    printf '# Generated by vault-manager\n'
    printf '# Source this file to use the initialized Vault root token.\n'
    printf 'export VAULT_ADDR=%q\n' "$VC_ADDR"
    [ -z "$VC_CACERT" ] || printf 'export VAULT_CACERT=%q\n' "$VC_CACERT"
    [ -z "$VC_NAMESPACE" ] || printf 'export VAULT_NAMESPACE=%q\n' "$VC_NAMESPACE"
    printf 'export VAULT_TOKEN=%q\n' "$token"
  } >"$tmp"

  run_root install -m 0600 "$tmp" "$acl_file"
  run_root chown "${target_uid}:${target_gid}" "$acl_file" 2>/dev/null || true
  rm -f "$tmp"
  log_info "Vault ACL env saved to ${acl_file} for ${target_user}"
}

remove_vault_acl_env_file() {
  local target_user=""
  local target_uid=""
  local target_gid=""
  local target_home=""
  local acl_file=""
  local first_line=""

  if ! command_exists python3; then
    log_warn "python3 not found; skip vault.acl cleanup"
    return 0
  fi

  {
    IFS= read -r target_user
    IFS= read -r target_uid
    IFS= read -r target_gid
    IFS= read -r target_home
    IFS= read -r acl_file
  } < <(target_vault_acl_info)

  [ -f "$acl_file" ] || return 0
  first_line="$(head -n 1 "$acl_file" 2>/dev/null || true)"
  if [ "$first_line" != "# Generated by vault-manager" ]; then
    log_warn "Preserving unmanaged Vault ACL env file: ${acl_file}"
    return 0
  fi

  log_info "Removing Vault ACL env file: ${acl_file}"
  run_root rm -f "$acl_file"
}

vault_cli() {
  local token=""
  local -a env_vars

  [ -x "$BIN_PATH" ] || fatal "Vault binary not found: ${BIN_PATH}. Please run install first"
  if [ -n "$VC_TOKEN_FILE" ]; then
    token="$(read_vault_token_file "$VC_TOKEN_FILE")"
    [ -n "$token" ] || fatal "Token file does not contain a token: ${VC_TOKEN_FILE}"
  fi

  env_vars=("VAULT_ADDR=${VC_ADDR}")
  [ -z "$VC_CACERT" ] || env_vars+=("VAULT_CACERT=${VC_CACERT}")
  [ -z "$VC_NAMESPACE" ] || env_vars+=("VAULT_NAMESPACE=${VC_NAMESPACE}")
  [ -z "$token" ] || env_vars+=("VAULT_TOKEN=${token}")
  env "${env_vars[@]}" "$BIN_PATH" "$@"
}

parse_common_vault_option() {
  case "$1" in
    --addr)
      printf 'addr\n'
      ;;
    --ca-cert)
      printf 'ca-cert\n'
      ;;
    --namespace)
      printf 'namespace\n'
      ;;
    --token-file)
      printf 'token-file\n'
      ;;
    *)
      return 1
      ;;
  esac
}

set_common_vault_option() {
  local name="$1"
  local value="$2"

  case "$name" in
    addr)
      VC_ADDR="$value"
      ;;
    ca-cert)
      VC_CACERT="$value"
      ;;
    namespace)
      VC_NAMESPACE="$value"
      ;;
    token-file)
      VC_TOKEN_FILE="$value"
      ;;
  esac
}

vault_status_json() {
  vault_cli status -format=json 2>/dev/null || true
}

vault_status_field() {
  local field="$1"
  local json

  json="$(vault_status_json)"
  [ -n "$json" ] || return 1
  python3 - "$field" "$json" <<'PY'
import json
import sys

data = json.loads(sys.argv[2])
value = data.get(sys.argv[1])
if isinstance(value, bool):
    print("true" if value else "false")
elif value is not None:
    print(value)
PY
}

status_vault() {
  local opt

  reset_vault_cli_opts
  while [ "$#" -gt 0 ]; do
    if opt="$(parse_common_vault_option "$1")"; then
      shift
      [ "$#" -gt 0 ] || fatal "Missing value for --${opt}"
      set_common_vault_option "$opt" "$1"
    elif [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
      status_usage
      exit 0
    else
      fatal "Unknown status option: $1"
    fi
    shift
  done

  vault_cli status
}

doctor_check_print() {
  local status="$1"
  local message="$2"

  printf '%-5s %s\n' "$status" "$message"
}

doctor_vault() {
  local failures=0
  local code
  local url
  local opt
  local -a curl_args

  reset_vault_cli_opts
  while [ "$#" -gt 0 ]; do
    if opt="$(parse_common_vault_option "$1")"; then
      shift
      [ "$#" -gt 0 ] || fatal "Missing value for --${opt}"
      set_common_vault_option "$opt" "$1"
    elif [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
      doctor_usage
      exit 0
    else
      fatal "Unknown doctor option: $1"
    fi
    shift
  done

  if [ -x "$BIN_PATH" ]; then
    doctor_check_print "OK" "Vault binary found: ${BIN_PATH}"
  else
    doctor_check_print "FAIL" "Vault binary missing: ${BIN_PATH}"
    failures=$((failures + 1))
  fi

  if [ -f "$CONFIG_FILE" ]; then
    if is_managed_file "$CONFIG_FILE"; then
      doctor_check_print "OK" "Vault config managed: ${CONFIG_FILE}"
    else
      doctor_check_print "WARN" "Vault config exists but is not managed: ${CONFIG_FILE}"
    fi
  else
    doctor_check_print "WARN" "Vault config missing: ${CONFIG_FILE}"
  fi

  if command_exists systemctl && systemctl is-active --quiet vault; then
    doctor_check_print "OK" "vault.service is active"
  else
    doctor_check_print "WARN" "vault.service is not active"
  fi

  if command_exists curl; then
    url="${VC_ADDR%/}/v1/sys/health"
    curl_args=(--noproxy '*' --silent --output /dev/null --write-out '%{http_code}' --max-time 5)
    [ -z "$VC_CACERT" ] || curl_args+=(--cacert "$VC_CACERT")
    code="$(curl "${curl_args[@]}" "$url" 2>/dev/null || true)"
    case "$code" in
      200 | 429 | 472 | 473)
        doctor_check_print "OK" "Vault health endpoint reachable: ${url} (${code})"
        ;;
      501 | 503)
        doctor_check_print "WARN" "Vault health endpoint reachable but not ready: ${url} (${code})"
        ;;
      *)
        doctor_check_print "FAIL" "Vault health endpoint not reachable: ${url} (${code:-curl failed})"
        failures=$((failures + 1))
        ;;
    esac
  else
    doctor_check_print "FAIL" "curl command not found"
    failures=$((failures + 1))
  fi

  return "$failures"
}

init_vault() {
  local key_shares=5
  local key_threshold=3
  local out="${INIT_DIR}/vault-init.json"
  local force=0
  local initialized
  local opt
  local tmp

  reset_vault_cli_opts
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --key-shares)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --key-shares"
        key_shares="$1"
        ;;
      --key-threshold)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --key-threshold"
        key_threshold="$1"
        ;;
      --out)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --out"
        out="$1"
        ;;
      --force)
        force=1
        ;;
      -h | --help)
        init_usage
        exit 0
        ;;
      *)
        if opt="$(parse_common_vault_option "$1")"; then
          shift
          [ "$#" -gt 0 ] || fatal "Missing value for --${opt}"
          set_common_vault_option "$opt" "$1"
        else
          fatal "Unknown init option: $1"
        fi
        ;;
    esac
    shift
  done

  initialized="$(vault_status_field initialized || true)"
  if [ "$initialized" = "true" ]; then
    fatal "Vault is already initialized"
  fi

  if [ -e "$out" ] && [ "$force" -ne 1 ]; then
    fatal "Output exists, use --force to overwrite: ${out}"
  fi

  tmp="$(mktemp)"
  umask 077
  log_info "Initializing Vault: key-shares=${key_shares} key-threshold=${key_threshold} out=${out}"
  vault_cli operator init -format=json -key-shares="$key_shares" -key-threshold="$key_threshold" >"$tmp"

  run_root install -d -m 0700 "$(dirname "$out")"
  run_root install -m 0600 "$tmp" "$out"
  write_vault_acl_env_file "$tmp"
  rm -f "$tmp"
  log_info "Vault init output saved: ${out}"
}

validate_unseal_keys_file() {
  local path="$1"
  local dir

  dir="$(dirname "$path")"

  if [ ! -d "$dir" ]; then
    if [ -e "$dir" ]; then
      fatal "Keys file parent path is not a directory: ${dir}"
    fi
    fatal "Keys file directory not found or inaccessible: ${dir}"
  fi
  [ -x "$dir" ] || fatal "Keys file directory is not accessible: ${dir}"
  [ -e "$path" ] || fatal "Keys file not found: ${path}"
  [ -f "$path" ] || fatal "Keys file is not a regular file: ${path}"
  [ -r "$path" ] || fatal "Keys file is not readable: ${path}"
}

unseal_keys_from_file() {
  local path="$1"

  require_command python3
  python3 - "$path" <<'PY'
import json
import sys

path = sys.argv[1]
try:
    with open(path, "r", encoding="utf-8") as f:
        data = json.load(f)
except OSError as exc:
    print(f"Failed to open keys file: {exc}", file=sys.stderr)
    raise SystemExit(1)
except json.JSONDecodeError as exc:
    print(f"Failed to parse keys file JSON: {exc}", file=sys.stderr)
    raise SystemExit(1)

keys = data.get("unseal_keys_b64") or data.get("unseal_keys_hex") or []
for key in keys:
    print(key)
PY
}

unseal_vault() {
  local keys_file=""
  local keys_output=""
  local sealed
  local opt
  local key
  local applied_keys=0

  reset_vault_cli_opts
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --keys-file)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --keys-file"
        keys_file="$1"
        ;;
      -h | --help)
        unseal_usage
        exit 0
        ;;
      *)
        if opt="$(parse_common_vault_option "$1")"; then
          shift
          [ "$#" -gt 0 ] || fatal "Missing value for --${opt}"
          set_common_vault_option "$opt" "$1"
        else
          fatal "Unknown unseal option: $1"
        fi
        ;;
    esac
    shift
  done

  [ -n "$keys_file" ] || fatal "unseal requires --keys-file"
  sealed="$(vault_status_field sealed || true)"
  if [ "$sealed" = "false" ]; then
    log_info "Vault is already unsealed"
    return
  fi

  validate_unseal_keys_file "$keys_file"
  if ! keys_output="$(unseal_keys_from_file "$keys_file")"; then
    fatal "Failed to read keys file: ${keys_file}"
  fi

  while IFS= read -r key; do
    [ -n "$key" ] || continue
    applied_keys=$((applied_keys + 1))
    vault_cli operator unseal "$key" >/dev/null
    sealed="$(vault_status_field sealed || true)"
    if [ "$sealed" = "false" ]; then
      log_info "Vault unsealed"
      return
    fi
  done <<<"$keys_output"

  [ "$applied_keys" -gt 0 ] || fatal "Keys file does not contain unseal keys: ${keys_file}"

  fatal "Vault is still sealed after applying keys"
}

auth_usage() {
  cat <<EOF
Vault auth method management

List, enable, configure and disable Vault auth methods through repeatable
manager commands.

Usage:
  ${VAULT_MANAGER_CMD} auth list [vault options]
  ${VAULT_MANAGER_CMD} auth enable <TYPE> [--path <PATH>] [--description <TEXT>] [--default-lease-ttl <DURATION>] [--max-lease-ttl <DURATION>] [vault options]
  ${VAULT_MANAGER_CMD} auth disable <PATH> [vault options]
  ${VAULT_MANAGER_CMD} auth read <PATH> [vault options]
  ${VAULT_MANAGER_CMD} auth write <PATH> <KEY=VALUE>... [vault options]

Auth commands:
  list                       Show enabled auth methods.
  enable <TYPE>              Enable auth method <TYPE>; default mount path is <TYPE>.
  disable <PATH>             Disable auth method at <PATH>.
  read <PATH>                Read auth/<PATH>.
  write <PATH> <KEY=VALUE>   Write <KEY=VALUE> pairs to auth/<PATH>.

Options for enable:
  --path <PATH>               Mount path, default: <TYPE>
  --description <TEXT>        Auth method description
  --default-lease-ttl <DURATION>
  --max-lease-ttl <DURATION>

Vault options:
  --addr <URL>                Vault address, default: ${CLIENT_ENV_FILE} or ${DEFAULT_VAULT_ADDR}
  --ca-cert <FILE>            Vault CA certificate file
  --namespace <NAME>          Vault Enterprise namespace
  --token-file <FILE>         Read token from plain text or init JSON file

Behavior:
  enable is idempotent when <PATH> already exists with the same <TYPE>.
  enable fails when <PATH> already exists with a different <TYPE>.
  disable is idempotent when <PATH> is already absent.
  read/write map directly to vault read/write under auth/<PATH>.
  The manager does not interpret auth-specific config keys.

Security:
  auth write <KEY=VALUE> arguments may appear in shell history and audit logs.
  Avoid passing secret values directly on the command line.

Examples:
  ${VAULT_MANAGER_CMD} auth list --token-file /opt/vault/init/vault-init.json
  ${VAULT_MANAGER_CMD} auth enable userpass --token-file /opt/vault/init/vault-init.json
  ${VAULT_MANAGER_CMD} auth enable jwt --path jwt-nomad --description "Nomad workload identity" --token-file /opt/vault/init/vault-init.json
  ${VAULT_MANAGER_CMD} auth write jwt-nomad/config jwks_url=http://127.0.0.1:4646/.well-known/jwks.json default_role=nomad-workloads --token-file /opt/vault/init/vault-init.json
  ${VAULT_MANAGER_CMD} auth read jwt-nomad/config --token-file /opt/vault/init/vault-init.json
  ${VAULT_MANAGER_CMD} auth disable userpass --token-file /opt/vault/init/vault-init.json
EOF
}

policy_usage() {
  cat <<EOF
Vault policy management

List, read, write and delete Vault policies from local HCL files.

Usage:
  ${VAULT_MANAGER_CMD} policy list [vault options]
  ${VAULT_MANAGER_CMD} policy read <NAME> [vault options]
  ${VAULT_MANAGER_CMD} policy write <NAME> <FILE> [vault options]
  ${VAULT_MANAGER_CMD} policy delete <NAME> [vault options]

Policy commands:
  list                 Show policy names.
  read <NAME>          Print policy HCL.
  write <NAME> <FILE>  Create or update policy <NAME> from <FILE>.
  delete <NAME>        Delete policy <NAME>.

Vault options:
  --addr <URL>      Vault address, default: ${CLIENT_ENV_FILE} or ${DEFAULT_VAULT_ADDR}
  --ca-cert <FILE>  Vault CA certificate file
  --namespace <NAME>  Vault Enterprise namespace
  --token-file <FILE> Read token from plain text or init JSON file

Policy file example:
  path "kv/data/app/*" {
    capabilities = ["read"]
  }

  path "kv/metadata/app/*" {
    capabilities = ["read", "list"]
  }

Behavior:
  write is idempotent for the same policy content.
  delete maps to "vault policy delete" and fails if Vault rejects the operation.
  The manager checks that <FILE> exists before writing a policy.
  Keep policy files under source control when possible.

Examples:
  ${VAULT_MANAGER_CMD} policy list --token-file /opt/vault/init/vault-init.json
  ${VAULT_MANAGER_CMD} policy write app-read ./policy.hcl --token-file /opt/vault/init/vault-init.json
  ${VAULT_MANAGER_CMD} policy read app-read --token-file /opt/vault/init/vault-init.json
  ${VAULT_MANAGER_CMD} policy delete app-read --token-file /opt/vault/init/vault-init.json
EOF
}

auth_type_at_path() {
  local path="$1"
  local json

  json="$(vault_cli auth list -format=json 2>/dev/null)" || return 2
  python3 - "$path" "$json" <<'PY'
import json
import sys

path = sys.argv[1].strip("/")
if path:
    path = path + "/"
data = json.loads(sys.argv[2])
print(data.get(path, {}).get("type", ""))
PY
}

auth_list() {
  vault_cli auth list
}

auth_enable() {
  local type="${1:-}"
  local path=""
  local description=""
  local default_ttl=""
  local max_ttl=""
  local existing_type
  local opt
  local -a args

  [ -n "$type" ] || fatal "auth enable requires TYPE"
  shift || true
  path="$type"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --path)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --path"
        path="$1"
        ;;
      --description)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --description"
        description="$1"
        ;;
      --default-lease-ttl)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --default-lease-ttl"
        default_ttl="$1"
        ;;
      --max-lease-ttl)
        shift
        [ "$#" -gt 0 ] || fatal "Missing value for --max-lease-ttl"
        max_ttl="$1"
        ;;
      *)
        if opt="$(parse_common_vault_option "$1")"; then
          shift
          [ "$#" -gt 0 ] || fatal "Missing value for --${opt}"
          set_common_vault_option "$opt" "$1"
        else
          fatal "Unknown auth enable option: $1"
        fi
        ;;
    esac
    shift
  done

  existing_type="$(auth_type_at_path "$path" || true)"
  if [ -n "$existing_type" ]; then
    if [ "$existing_type" = "$type" ]; then
      log_info "Auth method already enabled: ${path} (${type})"
      return
    fi
    fatal "Auth path ${path} already exists with type ${existing_type}"
  fi

  args=("auth" "enable" "-path=${path}")
  [ -z "$description" ] || args+=("-description=${description}")
  [ -z "$default_ttl" ] || args+=("-default-lease-ttl=${default_ttl}")
  [ -z "$max_ttl" ] || args+=("-max-lease-ttl=${max_ttl}")
  args+=("$type")
  vault_cli "${args[@]}"
}

auth_disable() {
  local path="${1:-}"
  local existing_type

  [ -n "$path" ] || fatal "auth disable requires PATH"
  shift || true
  parse_trailing_vault_options "$@" || fatal "auth disable accepts only vault options after PATH"

  existing_type="$(auth_type_at_path "$path" || true)"
  if [ -z "$existing_type" ]; then
    log_info "Auth method already absent: ${path}"
    return
  fi

  vault_cli auth disable "$path"
}

auth_read() {
  local path="${1:-}"

  [ -n "$path" ] || fatal "auth read requires PATH"
  shift || true
  parse_trailing_vault_options "$@" || fatal "auth read accepts only vault options after PATH"
  vault_cli read "auth/${path}"
}

auth_write() {
  local path="${1:-}"

  [ -n "$path" ] || fatal "auth write requires PATH"
  shift || true
  parse_key_values_and_vault_options "$@"
  [ "${#KV_ARGS[@]}" -gt 0 ] || fatal "auth write requires KEY=VALUE arguments"
  vault_cli write "auth/${path}" "${KV_ARGS[@]}"
}

parse_trailing_vault_options() {
  local opt

  while [ "$#" -gt 0 ]; do
    if opt="$(parse_common_vault_option "$1")"; then
      shift
      [ "$#" -gt 0 ] || fatal "Missing value for --${opt}"
      set_common_vault_option "$opt" "$1"
    else
      return 1
    fi
    shift
  done
}

KV_ARGS=()
parse_key_values_and_vault_options() {
  local opt

  KV_ARGS=()
  while [ "$#" -gt 0 ]; do
    if opt="$(parse_common_vault_option "$1")"; then
      shift
      [ "$#" -gt 0 ] || fatal "Missing value for --${opt}"
      set_common_vault_option "$opt" "$1"
    else
      KV_ARGS+=("$1")
    fi
    shift
  done
}

dispatch_auth() {
  local command="${1:-help}"

  reset_vault_cli_opts
  [ "$#" -eq 0 ] || shift
  case "$command" in
    list)
      case "${1:-}" in
        -h | --help)
          auth_usage
          return 0
          ;;
      esac
      parse_trailing_vault_options "$@" || fatal "auth list accepts only vault options"
      auth_list
      ;;
    enable)
      case "${1:-}" in
        -h | --help)
          auth_usage
          return 0
          ;;
      esac
      auth_enable "$@"
      ;;
    disable)
      case "${1:-}" in
        -h | --help)
          auth_usage
          return 0
          ;;
      esac
      auth_disable "$@"
      ;;
    read)
      case "${1:-}" in
        -h | --help)
          auth_usage
          return 0
          ;;
      esac
      auth_read "$@"
      ;;
    write)
      case "${1:-}" in
        -h | --help)
          auth_usage
          return 0
          ;;
      esac
      auth_write "$@"
      ;;
    help | -h | --help)
      auth_usage
      ;;
    *)
      auth_usage >&2
      fatal "Unknown auth command: ${command}"
      ;;
  esac
}

policy_list() {
  parse_trailing_vault_options "$@" || fatal "policy list accepts only vault options"
  vault_cli policy list
}

policy_read() {
  local name="${1:-}"

  [ -n "$name" ] || fatal "policy read requires NAME"
  shift || true
  parse_trailing_vault_options "$@" || fatal "policy read accepts only vault options after NAME"
  vault_cli policy read "$name"
}

policy_write() {
  local name="${1:-}"
  local file="${2:-}"

  [ -n "$name" ] || fatal "policy write requires NAME"
  [ -n "$file" ] || fatal "policy write requires FILE"
  [ -f "$file" ] || fatal "Policy file not found: ${file}"
  shift 2 || true
  parse_trailing_vault_options "$@" || fatal "policy write accepts only vault options after FILE"
  vault_cli policy write "$name" "$file"
}

policy_delete() {
  local name="${1:-}"

  [ -n "$name" ] || fatal "policy delete requires NAME"
  shift || true
  parse_trailing_vault_options "$@" || fatal "policy delete accepts only vault options after NAME"
  vault_cli policy delete "$name"
}

dispatch_policy() {
  local command="${1:-help}"

  reset_vault_cli_opts
  [ "$#" -eq 0 ] || shift
  case "$command" in
    list)
      case "${1:-}" in
        -h | --help)
          policy_usage
          return 0
          ;;
      esac
      policy_list "$@"
      ;;
    read)
      case "${1:-}" in
        -h | --help)
          policy_usage
          return 0
          ;;
      esac
      policy_read "$@"
      ;;
    write)
      case "${1:-}" in
        -h | --help)
          policy_usage
          return 0
          ;;
      esac
      policy_write "$@"
      ;;
    delete)
      case "${1:-}" in
        -h | --help)
          policy_usage
          return 0
          ;;
      esac
      policy_delete "$@"
      ;;
    help | -h | --help)
      policy_usage
      ;;
    *)
      policy_usage >&2
      fatal "Unknown policy command: ${command}"
      ;;
  esac
}

dispatch_tutor() {
  local topic="${1:-overview}"

  [ "$#" -le 1 ] || fatal "tutor accepts at most one topic"
  if ! tutor_usage "$topic"; then
    tutor_usage >&2
    fatal "Unknown tutor topic: ${topic}"
  fi
}

dispatch_tools() {
  local command="${1:-help}"

  if [ "$#" -gt 0 ]; then
    shift
  fi

  case "$command" in
    update)
      tools_update "$@"
      ;;
    help | -h | --help)
      tools_usage
      ;;
    *)
      tools_usage >&2
      fatal "Unknown tools command: ${command}"
      ;;
  esac
}

main() {
  local command="${1:-help}"

  if [ "$#" -gt 0 ]; then
    shift
  fi

  case "$command" in
    install)
      case "${1:-}" in
        -h | --help)
          install_usage
          return 0
          ;;
      esac
      install_vault "$@"
      ;;
    uninstall)
      case "${1:-}" in
        -h | --help)
          uninstall_usage
          return 0
          ;;
      esac
      uninstall_vault "$@"
      ;;
    tools)
      dispatch_tools "$@"
      ;;
    status)
      case "${1:-}" in
        -h | --help)
          status_usage
          return 0
          ;;
      esac
      status_vault "$@"
      ;;
    doctor)
      case "${1:-}" in
        -h | --help)
          doctor_usage
          return 0
          ;;
      esac
      doctor_vault "$@"
      ;;
    init)
      case "${1:-}" in
        -h | --help)
          init_usage
          return 0
          ;;
      esac
      init_vault "$@"
      ;;
    unseal)
      case "${1:-}" in
        -h | --help)
          unseal_usage
          return 0
          ;;
      esac
      unseal_vault "$@"
      ;;
    auth)
      dispatch_auth "$@"
      ;;
    policy)
      dispatch_policy "$@"
      ;;
    tutor)
      dispatch_tutor "$@"
      ;;
    help | -h | --help)
      usage
      ;;
    *)
      usage >&2
      fatal "Unknown command: ${command}"
      ;;
  esac
}

run_with_audit() {
  local exit_code=0
  local command_line
  local quiet_help=0
  local arg

  AUDIT_ACTIVE=1
  AUDIT_FINALIZED=0
  AUDIT_ERROR=""
  AUDIT_ARGS=("$@")
  command_line="$(redacted_command_line "$@")"
  if [ "$#" -eq 0 ]; then
    quiet_help=1
  else
    case "${1:-}" in
      tutor | help | -h | --help)
        quiet_help=1
        ;;
      *)
        for arg in "$@"; do
          case "$arg" in
            help | -h | --help)
              quiet_help=1
              break
              ;;
          esac
        done
        ;;
    esac
  fi
  audit_record "started" 0 "$@"

  set -E
  trap 'handle_unexpected_error "$?" "$LINENO" "$BASH_COMMAND" "$command_line"' ERR
  main "$@"
  trap - ERR

  [ "$quiet_help" -eq 1 ] || log_info "Completed vault-manager command: ${command_line}"
  audit_record "success" 0 "$@"
  AUDIT_FINALIZED=1
  return 0
}

run_with_audit "$@"
